<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CMMS PRO</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#0a0c10;--su:#13161d;--s2:#1a1e28;--s3:#20253300;
  --bd:#252b3a;--bd2:#353d52;
  --ac:#00c8ff;--a2:#ff6030;--a3:#00e676;--a4:#b060ff;--a5:#ffcc00;
  --tx:#e4e8f2;--t2:#7a8699;--t3:#3d4559;
  --rd:#ff3b3b;--wn:#ffaa00;--ok:#00e676;
  --ff:'IBM Plex Sans Thai',sans-serif;--fm:'IBM Plex Mono',monospace;
}
body,#root{background:var(--bg);color:var(--tx);font-family:var(--ff);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(circle at 20% 20%, rgba(0,200,255,.03) 0%, transparent 50%),radial-gradient(circle at 80% 80%, rgba(176,96,255,.03) 0%, transparent 50%);pointer-events:none;z-index:0;}
::-webkit-scrollbar{width:4px;height:4px;}::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:4px;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;padding:8px 14px;border-radius:8px;font-family:var(--ff);font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .15s;white-space:nowrap;line-height:1;}
.btn:disabled{opacity:.4;cursor:not-allowed;}
.bp{background:var(--ac);color:#000;}.bp:hover:not(:disabled){filter:brightness(1.1);}
.bu{background:var(--a2);color:#fff;}.bu:hover:not(:disabled){filter:brightness(1.1);}
.bg{background:var(--su);border:1px solid var(--bd);color:var(--t2);}.bg:hover:not(:disabled){border-color:var(--ac);color:var(--ac);}
.bok{background:rgba(0,230,118,.1);color:var(--ok);border:1px solid rgba(0,230,118,.25);}.bok:hover:not(:disabled){background:rgba(0,230,118,.2);}
.bdl{background:rgba(255,59,59,.08);color:var(--rd);border:1px solid rgba(255,59,59,.2);}.bdl:hover:not(:disabled){background:rgba(255,59,59,.18);}
.bwn{background:rgba(255,170,0,.08);color:var(--wn);border:1px solid rgba(255,170,0,.2);}.bwn:hover:not(:disabled){background:rgba(255,170,0,.18);}
.bpu{background:rgba(176,96,255,.1);color:var(--a4);border:1px solid rgba(176,96,255,.25);}.bpu:hover:not(:disabled){background:rgba(176,96,255,.2);}
.ico{width:28px;height:28px;border-radius:6px;background:var(--su);border:1px solid var(--bd);display:grid;place-items:center;cursor:pointer;color:var(--t2);font-size:13px;transition:all .12s;flex-shrink:0;}
.ico:hover{border-color:var(--ac);color:var(--ac);}
.ico.d:hover{border-color:var(--rd);color:var(--rd);}

/* BADGES */
.bdg{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:4px;font-size:11px;font-family:var(--fm);font-weight:500;white-space:nowrap;}
.b-sop{background:rgba(255,96,48,.1);color:var(--a2);border:1px solid rgba(255,96,48,.25);}
.b-sip{background:rgba(0,200,255,.08);color:var(--ac);border:1px solid rgba(0,200,255,.2);}
.b-sdn{background:rgba(0,230,118,.07);color:var(--ok);border:1px solid rgba(0,230,118,.2);}
.b-spd{background:rgba(176,96,255,.1);color:var(--a4);border:1px solid rgba(176,96,255,.25);}
.b-pcr{background:rgba(255,59,59,.12);color:var(--rd);border:1px solid rgba(255,59,59,.25);}
.b-phi{background:rgba(255,170,0,.1);color:var(--wn);border:1px solid rgba(255,170,0,.25);}
.b-pme{background:rgba(0,200,255,.08);color:var(--ac);border:1px solid rgba(0,200,255,.2);}
.b-plo{background:rgba(0,230,118,.07);color:var(--a3);border:1px solid rgba(0,230,118,.2);}
.newdot{width:6px;height:6px;border-radius:50%;background:var(--a2);box-shadow:0 0 5px var(--a2);display:inline-block;margin-left:5px;vertical-align:middle;}

/* TOAST */
.toast-w{position:fixed;bottom:18px;right:18px;z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;}
.tst{background:var(--s2);border-left:3px solid var(--ac);border-radius:8px;padding:10px 15px;font-size:13px;box-shadow:0 6px 24px rgba(0,0,0,.6);animation:tin .2s ease;max-width:280px;pointer-events:all;}
.tst.err{border-color:var(--rd);}.tst.warn{border-color:var(--wn);}
@keyframes tin{from{transform:translateX(8px);opacity:0;}to{opacity:1;}}

/* INPUTS */
.fi{background:var(--su);border:1px solid var(--bd);border-radius:8px;color:var(--tx);font-family:var(--ff);font-size:13px;padding:9px 12px;outline:none;width:100%;transition:border-color .15s;}
.fi:focus{border-color:var(--ac);box-shadow:0 0 0 3px rgba(0,200,255,.05);}
.fi.err{border-color:var(--rd);}
textarea.fi{resize:vertical;min-height:80px;line-height:1.6;}
select.fi{cursor:pointer;}
.lbl{font-size:11px;font-weight:700;color:var(--t2);letter-spacing:.05em;text-transform:uppercase;display:block;margin-bottom:5px;}
.req{color:var(--rd);}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
.fgg{display:flex;flex-direction:column;}
.full{grid-column:1/-1;}
.err-box{background:rgba(255,59,59,.07);border:1px solid rgba(255,59,59,.25);border-radius:6px;padding:8px 12px;font-size:12px;color:var(--rd);margin-bottom:12px;}

/* LOGIN */
.login-wrap{position:fixed;inset:0;z-index:200;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--bg);}
.login-box{background:var(--su);border:1px solid var(--bd);border-radius:18px;padding:34px 30px;width:100%;max-width:360px;position:relative;z-index:1;}
.role-tabs{display:flex;background:var(--bg);border-radius:8px;padding:3px;margin-bottom:18px;}
.rtab{flex:1;padding:8px;text-align:center;border-radius:6px;cursor:pointer;font-size:13px;font-weight:600;color:var(--t2);transition:all .15s;}
.rtab.on{background:var(--s2);color:var(--tx);}

/* HEADER */
.hdr{position:sticky;top:0;z-index:60;background:rgba(10,12,16,.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--bd);height:52px;display:flex;align-items:center;padding:0 16px;gap:10px;}
.hdr-logo{display:flex;align-items:center;gap:9px;margin-right:auto;}
.hdr-logo-ic{width:28px;height:28px;border-radius:8px;display:grid;place-items:center;font-size:14px;}
#h-user{font-size:12px;color:var(--t2);font-family:var(--fm);background:var(--s2);border:1px solid var(--bd);border-radius:20px;padding:3px 10px;}

/* LAYOUT */
.layout{display:grid;grid-template-columns:215px 1fr;min-height:calc(100vh - 52px);}
.side{border-right:1px solid var(--bd);padding:12px 0;position:sticky;top:52px;height:calc(100vh - 52px);overflow-y:auto;}
.sb-s{padding:0 10px;margin-bottom:16px;}
.sb-l{font-family:var(--fm);font-size:10px;color:var(--t3);letter-spacing:.1em;text-transform:uppercase;padding:0 8px;margin-bottom:5px;}
.ni{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;cursor:pointer;transition:all .12s;font-size:13px;font-weight:500;color:var(--t2);}
.ni:hover{background:var(--s2);color:var(--tx);}
.ni.on{background:rgba(0,200,255,.07);color:var(--ac);border:1px solid rgba(0,200,255,.18);}
.ni-ic{width:18px;text-align:center;font-size:14px;}
.ni-cnt{margin-left:auto;background:var(--s2);font-family:var(--fm);font-size:11px;padding:1px 6px;border-radius:9px;min-width:20px;text-align:center;}
.ni.on .ni-cnt{background:rgba(0,200,255,.15);color:var(--ac);}
.ni.warn-item .ni-cnt{background:rgba(255,170,0,.15);color:var(--wn);}

/* STAT CARDS */
.sg{display:grid;grid-template-columns:repeat(4,1fr);gap:11px;padding:14px;border-bottom:1px solid var(--bd);}
.sc{background:var(--su);border:1px solid var(--bd);border-radius:10px;padding:13px 14px;position:relative;overflow:hidden;cursor:pointer;transition:all .13s;}
.sc:hover{border-color:var(--bd2);transform:translateY(-1px);}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.c1::before{background:var(--ac);}.c2::before{background:var(--wn);}
.c3::before{background:var(--rd);}.c4::before{background:var(--ok);}
.c5::before{background:var(--a4);}.c6::before{background:var(--a5);}
.sc-l{font-size:11px;color:var(--t2);margin-bottom:3px;}
.sc-v{font-family:var(--fm);font-size:24px;font-weight:700;line-height:1;}
.c1 .sc-v{color:var(--ac);}.c2 .sc-v{color:var(--wn);}
.c3 .sc-v{color:var(--rd);}.c4 .sc-v{color:var(--ok);}
.c5 .sc-v{color:var(--a4);}.c6 .sc-v{color:var(--a5);}
.sc-s{font-size:10px;color:var(--t3);margin-top:3px;font-family:var(--fm);}

/* CHARTS */
.chart-row{display:grid;grid-template-columns:2fr 1fr 1fr;gap:11px;padding:11px 14px;border-bottom:1px solid var(--bd);}
.chart-c{background:var(--su);border:1px solid var(--bd);border-radius:10px;padding:13px;}
.chart-t{font-size:11px;font-weight:700;color:var(--t2);margin-bottom:10px;text-transform:uppercase;letter-spacing:.04em;}

/* TOOLBAR */
.tbar{display:flex;align-items:center;gap:8px;padding:11px 14px;border-bottom:1px solid var(--bd);flex-wrap:wrap;}
.tbar-t{font-size:14px;font-weight:700;flex:1;}
.srch{display:flex;align-items:center;gap:7px;background:var(--su);border:1px solid var(--bd);border-radius:8px;padding:7px 10px;transition:border-color .15s;}
.srch:focus-within{border-color:var(--ac);}
.srch input{background:none;border:none;outline:none;color:var(--tx);font-family:var(--ff);font-size:13px;width:150px;}
.srch input::placeholder{color:var(--t3);}
.fsel{background:var(--su);border:1px solid var(--bd);color:var(--tx);padding:7px 9px;border-radius:8px;font-family:var(--ff);font-size:12px;cursor:pointer;outline:none;}
.fsel:focus{border-color:var(--ac);}

/* TABLE */
.tw{overflow-x:auto;}
table{width:100%;border-collapse:collapse;}
thead th{text-align:left;padding:8px 9px;font-family:var(--fm);font-size:10px;color:var(--t3);letter-spacing:.08em;text-transform:uppercase;border-bottom:1px solid var(--bd);white-space:nowrap;}
tbody tr{border-bottom:1px solid rgba(37,43,58,.5);transition:background .1s;cursor:pointer;}
tbody tr:hover{background:var(--s2);}
td{padding:9px;font-size:13px;vertical-align:middle;}
.tid{font-family:var(--fm);font-size:12px;color:var(--ac);font-weight:500;}
.emp{text-align:center;padding:46px 14px;color:var(--t3);}

/* FORM */
.fc{max-width:680px;margin:0 auto;padding:20px 14px;}
.fc-t{font-size:16px;font-weight:700;margin-bottom:3px;}
.fc-s{font-size:12px;color:var(--t2);margin-bottom:18px;}
.fa{display:flex;gap:10px;justify-content:flex-end;margin-top:16px;padding-top:14px;border-top:1px solid var(--bd);}

/* DETAIL PANEL */
.dp{position:fixed;right:0;top:52px;width:380px;height:calc(100vh - 52px);background:var(--su);border-left:1px solid var(--bd);z-index:50;display:flex;flex-direction:column;animation:si .18s ease;}
@keyframes si{from{transform:translateX(100%);}to{transform:translateX(0);}}
.dp-h{padding:13px 14px;border-bottom:1px solid var(--bd);display:flex;align-items:flex-start;gap:9px;}
.dp-b{flex:1;overflow-y:auto;padding:14px;}
.dp-tabs{display:flex;border-bottom:1px solid var(--bd);padding:0 14px;margin:-14px -14px 13px;}
.dtb{padding:8px 12px;font-size:12px;font-weight:600;cursor:pointer;color:var(--t3);border-bottom:2px solid transparent;transition:all .12s;}
.dtb.on{color:var(--ac);border-bottom-color:var(--ac);}
.dp-f{padding:11px 14px;border-top:1px solid var(--bd);display:flex;gap:6px;}
.dr{display:flex;flex-direction:column;gap:3px;margin-bottom:11px;}
.dk{font-size:10px;font-family:var(--fm);color:var(--t3);letter-spacing:.08em;text-transform:uppercase;}
.dv{font-size:13px;}
.ddc{background:var(--bg);border:1px solid var(--bd);border-radius:6px;padding:10px;font-size:12px;line-height:1.7;color:var(--t2);}
.div{border:none;border-top:1px solid var(--bd);margin:11px 0;}

/* TIMELINE */
.tl{list-style:none;padding:0;}
.tl-li{display:flex;gap:9px;margin-bottom:10px;font-size:12px;}
.tl-d{width:7px;height:7px;border-radius:50%;margin-top:3px;flex-shrink:0;}
.tl-acc{background:var(--ac);box-shadow:0 0 5px var(--ac);}
.tl-done{background:var(--ok);box-shadow:0 0 5px var(--ok);}
.tl-warn{background:var(--wn);box-shadow:0 0 5px var(--wn);}
.tl-at{color:var(--t3);font-family:var(--fm);font-size:11px;}
.tl-by{color:var(--t3);font-size:10px;}
.tl-msg{color:var(--t2);}

/* PM */
.pm-g{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:11px;padding:14px;}
.pm-c{background:var(--su);border:1px solid var(--bd);border-radius:10px;padding:14px;transition:all .14s;cursor:pointer;}
.pm-c:hover{border-color:var(--ac);transform:translateY(-1px);}
.pm-bg{background:var(--bg);border-radius:4px;height:4px;margin:9px 0 7px;overflow:hidden;}
.pm-bf{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--ac),var(--a4));}

/* SPARE PARTS */
.spare-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:11px;padding:14px;}
.spare-c{background:var(--su);border:1px solid var(--bd);border-radius:10px;padding:14px;cursor:pointer;transition:all .14s;}
.spare-c:hover{border-color:var(--ac);transform:translateY(-1px);}
.spare-c.low{border-color:rgba(255,170,0,.4);background:rgba(255,170,0,.03);}
.spare-c.critical{border-color:rgba(255,59,59,.4);background:rgba(255,59,59,.03);}
.spare-qty{font-family:var(--fm);font-size:22px;font-weight:700;}
.spare-unit{font-size:11px;color:var(--t2);margin-left:4px;}
.qty-bar-bg{background:var(--bg);border-radius:4px;height:3px;margin-top:8px;overflow:hidden;}
.qty-bar-fill{height:100%;border-radius:4px;transition:width .3s;}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;padding:14px;border-bottom:1px solid var(--bd);}
.kpi-c{background:var(--su);border:1px solid var(--bd);border-radius:10px;padding:16px;}
.kpi-v{font-family:var(--fm);font-size:28px;font-weight:700;line-height:1;margin-bottom:4px;}
.kpi-l{font-size:12px;color:var(--t2);margin-bottom:2px;}
.kpi-t{font-size:11px;color:var(--t3);font-family:var(--fm);}
.gauge-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center;}
.gauge-txt{position:absolute;font-family:var(--fm);font-size:14px;font-weight:700;text-align:center;}
.kpi-row{display:grid;grid-template-columns:1fr 1fr;gap:11px;padding:0 14px 14px;}
.kpi-chart-c{background:var(--su);border:1px solid var(--bd);border-radius:10px;padding:13px;}

/* SETTINGS */
.sec-c{background:var(--su);border:1px solid var(--bd);border-radius:10px;overflow:hidden;margin-bottom:12px;}
.sec-h{padding:11px 14px;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;}
.sec-h h3{font-size:13px;font-weight:700;}
.sec-b{padding:14px;}
.tag{display:inline-flex;align-items:center;gap:5px;background:var(--s2);border:1px solid var(--bd);border-radius:6px;padding:4px 9px;font-size:12px;margin:3px;}
.tag .x{cursor:pointer;color:var(--t3);}.tag .x:hover{color:var(--rd);}

/* TECH DASHBOARD */
.tech-dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:11px;padding:14px;border-bottom:1px solid var(--bd);}
.tdc{background:var(--su);border:1px solid var(--bd);border-radius:10px;padding:14px;}
.tdc h3{font-size:13px;font-weight:700;margin-bottom:12px;color:var(--t2);}
.my-ticket{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;cursor:pointer;transition:background .12s;border-bottom:1px solid rgba(37,43,58,.4);}
.my-ticket:hover{background:var(--s2);}
.my-ticket:last-child{border-bottom:none;}

/* USER PORTAL */
.u-hdr{position:sticky;top:0;z-index:60;background:rgba(10,12,16,.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--bd);height:50px;display:flex;align-items:center;padding:0 16px;gap:10px;}
.u-tabs{display:flex;border-bottom:1px solid var(--bd);background:var(--su);}
.u-tab{padding:11px 18px;font-size:13px;font-weight:600;cursor:pointer;color:var(--t3);border-bottom:2px solid transparent;transition:all .14s;}
.u-tab.on{color:var(--a2);border-bottom-color:var(--a2);}
.suc-w{display:flex;align-items:center;justify-content:center;min-height:55vh;padding:20px;}
.suc-c{background:rgba(0,230,118,.04);border:1px solid rgba(0,230,118,.2);border-radius:16px;padding:28px;text-align:center;max-width:380px;width:100%;}
.wo-ref{display:inline-block;background:var(--s2);border:1px solid rgba(0,200,255,.3);border-radius:8px;padding:9px 26px;margin:11px 0;font-family:var(--fm);font-size:21px;font-weight:700;color:var(--ac);letter-spacing:.12em;cursor:pointer;}

/* MODAL */
.mo-bg{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:300;display:flex;align-items:center;justify-content:center;padding:16px;}
.mo{background:var(--su);border:1px solid var(--bd);border-radius:14px;padding:22px;width:100%;max-width:500px;max-height:90vh;overflow-y:auto;animation:mup .16s ease;}
@keyframes mup{from{transform:translateY(8px);opacity:0;}to{opacity:1;}}
.mo-f{display:flex;gap:9px;justify-content:flex-end;margin-top:16px;padding-top:13px;border-top:1px solid var(--bd);}

/* SCREENS */
.screen{display:none;}
.screen.active{display:block;}
.view{display:none;}
.view.active{display:block;}

/* PROGRESS BAR */
.prog-bar-bg{background:var(--bg);border-radius:4px;height:6px;overflow:hidden;margin-top:6px;}
.prog-bar{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--ac),var(--a4));transition:width .4s;}

@media(max-width:820px){
  .layout{grid-template-columns:1fr;}.side{display:none;}
  .sg,.kpi-grid,.tech-dash-grid{grid-template-columns:1fr 1fr;}
  .chart-row,.kpi-row{grid-template-columns:1fr;}
  .dp{width:100%;top:0;height:100vh;}
  .fg2{grid-template-columns:1fr;}
}
</style>
</head>
<body>
<div class="toast-w" id="toast-area"></div>

<!-- LOGIN -->
<div id="scr-login" class="screen active" style="background:var(--bg);min-height:100vh;display:flex;align-items:center;justify-content:center;">
  <div class="login-box">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:22px;">
      <div style="width:44px;height:44px;background:linear-gradient(135deg,var(--ac),var(--a4));border-radius:12px;display:grid;place-items:center;font-size:22px;">⚙</div>
      <div><div style="font-family:var(--fm);font-size:18px;font-weight:700;color:var(--ac);">CMMS PRO</div><div style="font-size:11px;color:var(--t3);">ระบบแจ้งซ่อมและซ่อมบำรุง</div></div>
    </div>
    <h2 style="font-size:16px;font-weight:700;margin-bottom:3px;">เข้าสู่ระบบ</h2>
    <p style="font-size:12px;color:var(--t2);margin-bottom:16px;">เลือกบทบาทและกรอก PIN ของคุณ</p>
    <div class="role-tabs">
      <div class="rtab on" onclick="selRole('admin',this)">🛠 Admin</div>
      <div class="rtab" onclick="selRole('tech',this)">👷 Technician</div>
    </div>
    <label class="lbl">PIN <span class="req">*</span></label>
    <div style="display:flex;gap:9px;margin-bottom:6px;">
      <input class="fi" id="pin-input" type="password" inputmode="numeric" maxlength="8" placeholder="••••" style="flex:1;font-family:var(--fm);font-size:20px;letter-spacing:.15em;text-align:center;" onkeydown="if(event.key==='Enter')doLogin()"/>
      <button class="btn bp" onclick="doLogin()">เข้า →</button>
    </div>
    <div class="err-box" id="login-err" style="display:none;"></div>
    <div style="margin-top:16px;padding-top:14px;border-top:1px solid var(--bd);text-align:center;">
      <button class="btn bg" onclick="showUserPortal()" style="width:100%;font-size:12px;">📝 User Portal — แจ้งซ่อม/ติดตาม (ไม่ต้อง Login) →</button>
    </div>
  </div>
</div>

<!-- USER PORTAL -->
<div id="scr-user" class="screen">
  <header class="u-hdr">
    <div style="width:26px;height:26px;background:linear-gradient(135deg,var(--a2),var(--wn));border-radius:7px;display:grid;place-items:center;font-size:13px;">📝</div>
    <span style="font-family:var(--fm);font-size:13px;font-weight:500;">User Portal</span>
    <button class="btn bg" onclick="showLogin()" style="font-size:12px;margin-left:auto;">← กลับ</button>
  </header>
  <div class="u-tabs">
    <div class="u-tab on" id="ut-form" onclick="uTab('form',this)">✏️ แจ้งซ่อมใหม่</div>
    <div class="u-tab" id="ut-track" onclick="uTab('track',this)">🔍 ติดตามงาน</div>
  </div>
  <div id="uv-form">
    <div id="u-form-area" style="max-width:600px;margin:0 auto;padding:20px 14px;">
      <div style="background:linear-gradient(135deg,rgba(255,96,48,.07),rgba(255,204,0,.04));border:1px solid rgba(255,96,48,.18);border-radius:10px;padding:16px 18px;margin-bottom:16px;display:flex;gap:12px;">
        <div style="font-size:24px;flex-shrink:0;margin-top:2px;">🔧</div>
        <div><h2 style="font-size:15px;font-weight:700;margin-bottom:3px;">แจ้งซ่อมใหม่</h2><p style="font-size:12px;color:var(--t2);line-height:1.6;">กรอกข้อมูลที่มี <b style="color:var(--a2)">*</b> ให้ครบ จะได้รับ <b style="color:var(--a2)">เลขที่ใบแจ้งซ่อม (WO)</b></p></div>
      </div>
      <div class="err-box" id="uf-err" style="display:none;"></div>
      <div class="fg2">
        <div class="fgg"><label class="lbl">ชื่อผู้แจ้ง <span class="req">*</span></label><input class="fi" id="uf-name" placeholder="ชื่อ-นามสกุล"/></div>
        <div class="fgg"><label class="lbl">แผนก</label><input class="fi" id="uf-dept" placeholder="เช่น ฝ่ายผลิต"/></div>
        <div class="fgg"><label class="lbl">เบอร์โทร <span class="req">*</span></label><input class="fi" id="uf-phone" type="tel" placeholder="081-xxx-xxxx"/></div>
        <div class="fgg"><label class="lbl">สถานที่ <span class="req">*</span></label><input class="fi" id="uf-loc" placeholder="อาคาร/ชั้น/ห้อง"/></div>
        <div class="fgg full"><label class="lbl">หัวข้อปัญหา <span class="req">*</span></label><input class="fi" id="uf-title" placeholder="สรุปปัญหา เช่น แอร์ไม่เย็น"/></div>
        <div class="fgg"><label class="lbl">ประเภทงาน <span class="req">*</span></label><select class="fi" id="uf-type"><option value="">-- เลือก --</option><option>ไฟฟ้า</option><option>ประปา</option><option>เครื่องจักร</option><option>โครงสร้าง</option><option>แอร์/ระบบทำความเย็น</option><option>อื่นๆ</option></select></div>
        <div class="fgg"><label class="lbl">ระดับความเร่งด่วน <span class="req">*</span></label><select class="fi" id="uf-pri"><option value="">-- เลือก --</option><option value="Critical">🔴 วิกฤต</option><option value="High">🟠 เร่งด่วน</option><option value="Medium">🔵 ปานกลาง</option><option value="Low">🟢 ไม่เร่งด่วน</option></select></div>
        <div class="fgg full"><label class="lbl">รายละเอียด <span class="req">*</span></label><textarea class="fi" id="uf-desc" placeholder="อธิบายอาการ สาเหตุ ผลกระทบ..."></textarea></div>
      </div>
      <div class="fa"><button class="btn bg" onclick="resetUForm()">🗑 ล้าง</button><button class="btn bu" onclick="submitUForm()" id="uf-btn">📨 ส่งใบแจ้งซ่อม</button></div>
    </div>
    <div id="u-suc" style="display:none;"><div class="suc-w"><div class="suc-c">
      <div style="font-size:46px;margin-bottom:10px;">✅</div>
      <h2 style="font-size:17px;font-weight:700;color:var(--ok);margin-bottom:5px;">ส่งสำเร็จ!</h2>
      <p style="font-size:13px;color:var(--t2);margin-bottom:4px;">เลขที่ใบแจ้งซ่อม</p>
      <div class="wo-ref" id="suc-id" onclick="copyId()" title="คลิกเพื่อคัดลอก">WO-0000</div>
      <p style="font-size:11px;color:var(--t3);margin-bottom:16px;">📋 คลิกเพื่อคัดลอก · ใช้ติดตามงานได้</p>
      <div style="display:flex;gap:9px;justify-content:center;">
        <button class="btn bg" onclick="uTab('track',document.getElementById('ut-track'));document.getElementById('tr-inp').value=document.getElementById('suc-id').textContent;doTrack();">🔍 ติดตาม</button>
        <button class="btn bu" onclick="document.getElementById('u-suc').style.display='none';document.getElementById('u-form-area').style.display='block';resetUForm();">+ แจ้งซ่อมอีก</button>
      </div>
    </div></div></div>
  </div>
  <div id="uv-track" style="display:none;">
    <div style="max-width:600px;margin:0 auto;padding:20px 14px;">
      <div style="background:var(--su);border:1px solid var(--bd);border-radius:10px;padding:18px;margin-bottom:14px;">
        <h3 style="font-size:14px;font-weight:700;margin-bottom:5px;">🔍 ติดตามสถานะงาน</h3>
        <p style="font-size:12px;color:var(--t2);margin-bottom:11px;">กรอกเลขที่ใบแจ้งซ่อม เช่น <span style="font-family:var(--fm);color:var(--ac);">WO-0001</span></p>
        <div style="display:flex;gap:8px;">
          <input class="fi" id="tr-inp" style="flex:1;font-family:var(--fm);letter-spacing:.06em;" placeholder="WO-0001" oninput="this.value=this.value.toUpperCase()" onkeydown="if(event.key==='Enter')doTrack()"/>
          <button class="btn bu" onclick="doTrack()">ค้นหา</button>
        </div>
      </div>
      <div id="tr-result"></div>
    </div>
  </div>
</div>

<!-- ADMIN / TECH APP -->
<div id="scr-admin" class="screen">
  <header class="hdr">
    <div class="hdr-logo">
      <div class="hdr-logo-ic" style="background:linear-gradient(135deg,var(--ac),var(--a4));">⚙</div>
      <span style="font-family:var(--fm);font-size:13px;font-weight:600;"><b style="color:var(--ac);">CMMS</b> <span style="color:var(--t3);">PRO</span></span>
    </div>
    <span id="h-user"></span>
    <span id="h-cnt" style="background:var(--ac);color:#000;font-family:var(--fm);font-size:11px;font-weight:700;padding:3px 9px;border-radius:20px;"></span>
    <button class="btn bg" onclick="doLogout()" style="font-size:12px;padding:5px 10px;">ออก</button>
    <button class="btn bp" onclick="showView('new-ticket')" style="font-size:12px;">＋ แจ้งซ่อม</button>
  </header>

  <div class="layout">
    <aside class="side">
      <div class="sb-s">
        <div class="sb-l">เมนูหลัก</div>
        <div class="ni on" id="nav-dashboard" onclick="showView('dashboard')"><span class="ni-ic">📊</span>ภาพรวม</div>
        <div class="ni" id="nav-tickets" onclick="showView('tickets')"><span class="ni-ic">🔧</span>รายการแจ้งซ่อม<span class="ni-cnt" id="nc-open">0</span></div>
        <div class="ni" id="nav-pm" onclick="showView('pm')"><span class="ni-ic">📋</span>แผน PM<span class="ni-cnt" id="nc-pm">0</span></div>
        <div class="ni" id="nav-spare" onclick="showView('spare')"><span class="ni-ic">🗃️</span>คลังอะไหล่<span class="ni-cnt warn-item" id="nc-low">0</span></div>
        <div class="ni" id="nav-kpi" onclick="showView('kpi')"><span class="ni-ic">📈</span>KPI</div>
        <div class="ni admin-only" id="nav-settings" onclick="showView('settings')"><span class="ni-ic">⚙️</span>ตั้งค่า</div>
      </div>
      <div class="sb-s">
        <div class="sb-l">เมนูช่าง</div>
        <div class="ni tech-visible" id="nav-tech-dash" onclick="showView('tech-dash')"><span class="ni-ic">👷</span>Dashboard ช่าง</div>
        <div class="ni" id="nav-new-ticket" onclick="showView('new-ticket')"><span class="ni-ic">✏️</span>แจ้งซ่อมใหม่</div>
        <div class="ni tech-visible" id="nav-spare-txn" onclick="showView('spare-txn')"><span class="ni-ic">📦</span>เบิก/รับอะไหล่</div>
      </div>
      <div class="sb-s">
        <div class="sb-l">กรอง</div>
        <div class="ni" onclick="filterStatus('all');showView('tickets')"><span class="ni-ic">📁</span>ทั้งหมด<span class="ni-cnt" id="nc-all">0</span></div>
        <div class="ni" onclick="filterStatus('open');showView('tickets')"><span class="ni-ic">🔴</span>รอดำเนินการ<span class="ni-cnt" id="nc-s-open">0</span></div>
        <div class="ni" onclick="filterStatus('in-progress');showView('tickets')"><span class="ni-ic">🔵</span>กำลังซ่อม<span class="ni-cnt" id="nc-s-ip">0</span></div>
        <div class="ni" onclick="filterStatus('done');showView('tickets')"><span class="ni-ic">🟢</span>เสร็จสิ้น<span class="ni-cnt" id="nc-s-done">0</span></div>
        <div class="ni" onclick="filterStatus('pending');showView('tickets')"><span class="ni-ic">⚪</span>รอชิ้นส่วน<span class="ni-cnt" id="nc-s-pd">0</span></div>
      </div>
    </aside>

    <main id="main-content">
      <!-- DASHBOARD -->
      <div class="view active" id="view-dashboard"></div>
      <!-- TICKETS -->
      <div class="view" id="view-tickets"></div>
      <!-- PM -->
      <div class="view" id="view-pm"></div>
      <!-- SPARE -->
      <div class="view" id="view-spare"></div>
      <!-- KPI -->
      <div class="view" id="view-kpi"></div>
      <!-- SETTINGS -->
      <div class="view admin-only" id="view-settings"></div>
      <!-- TECH DASH -->
      <div class="view tech-visible" id="view-tech-dash"></div>
      <!-- NEW TICKET -->
      <div class="view" id="view-new-ticket"></div>
      <!-- SPARE TXN -->
      <div class="view tech-visible" id="view-spare-txn"></div>
    </main>
  </div>

  <!-- DETAIL PANEL -->
  <div class="dp" id="detail-panel" style="display:none;">
    <div class="dp-h">
      <div style="flex:1;min-width:0;">
        <div style="font-family:var(--fm);font-size:11px;color:var(--ac);margin-bottom:2px;" id="dp-id"></div>
        <div style="font-size:13px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" id="dp-title"></div>
      </div>
      <div class="ico" onclick="closeDetail()">✕</div>
    </div>
    <div class="dp-b">
      <div class="dp-tabs">
        <div class="dtb on" onclick="dpTab('info',this)">ข้อมูล</div>
        <div class="dtb" onclick="dpTab('tl',this)">Timeline</div>
        <div class="dtb" onclick="dpTab('comment',this)">💬 บันทึก</div>
      </div>
      <div id="dp-info"></div>
      <div id="dp-tl" style="display:none;"></div>
      <div id="dp-comment" style="display:none;"></div>
    </div>
    <div class="dp-f">
      <button class="btn bok" style="flex:1;justify-content:center;font-size:12px;" onclick="setStatus('done')">✅ ปิดงาน</button>
      <button class="btn bp" style="flex:1;justify-content:center;font-size:12px;" onclick="setStatus('in-progress')">🔧 เริ่มซ่อม</button>
      <button class="btn bwn" style="font-size:12px;" onclick="setStatus('pending')">⏳</button>
      <button class="btn bdl admin-only" style="font-size:12px;" onclick="doDelete()">🗑</button>
    </div>
  </div>
</div>

<!-- SPARE DETAIL MODAL -->
<div id="spare-detail-modal" style="display:none;" class="mo-bg" onclick="if(event.target===this)this.style.display='none'">
  <div class="mo" style="max-width:560px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;">
      <div id="sdm-title" style="font-size:16px;font-weight:700;"></div>
      <div class="ico" onclick="document.getElementById('spare-detail-modal').style.display='none'">✕</div>
    </div>
    <div id="sdm-body"></div>
  </div>
</div>

<!-- MODAL -->
<div id="modal-bg" style="display:none;" class="mo-bg" onclick="if(event.target===this)closeModal()">
  <div class="mo" id="modal-box">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
      <div><h3 id="modal-title" style="font-size:15px;font-weight:700;"></h3><div id="modal-sub" style="font-size:12px;color:var(--t2);margin-top:2px;"></div></div>
      <div class="ico" onclick="closeModal()">✕</div>
    </div>
    <div id="modal-body" style="margin-top:14px;"></div>
    <div class="mo-f" id="modal-foot"></div>
  </div>
</div>

<script>
/* ══ CONFIG ════════════════════════════════════════════ */
const BASE = window.location.origin;

/* ══ STATE ═════════════════════════════════════════════ */
let TOKEN = localStorage.getItem("cmms_token")||"";
let ROLE  = localStorage.getItem("cmms_role")||"";
let USER  = localStorage.getItem("cmms_user")||"";
let TECHS=[], ALL_TICKETS=[], ALL_SPARE=[], FILTER_STATUS="all";
let CURRENT_TK=null, CHARTS={};
let loginRole="admin";
let LAST_WO="";

/* ══ API ════════════════════════════════════════════════ */
async function api(method,path,body){
  const opts={method,headers:{"Content-Type":"application/json"}};
  if(TOKEN) opts.headers["Authorization"]="Bearer "+TOKEN;
  if(body) opts.body=JSON.stringify(body);
  const res=await fetch(BASE+path,opts);
  const data=await res.json();
  if(!res.ok){ if(res.status===401){doLogout();return null;} throw new Error(data.error||"เกิดข้อผิดพลาด"); }
  return data;
}

/* ══ TOAST ══════════════════════════════════════════════ */
let _toasts=[];
function toast(msg,tp="ok"){
  const el=document.createElement("div");
  el.className="tst"+(tp==="err"?" err":tp==="warn"?" warn":"");
  el.textContent=msg;
  document.getElementById("toast-area").appendChild(el);
  setTimeout(()=>el.remove(),3200);
}

/* ══ BADGES ═════════════════════════════════════════════ */
const SM={open:{l:"รอดำเนินการ",i:"🔴",c:"sop"},"in-progress":{l:"กำลังซ่อม",i:"🔵",c:"sip"},done:{l:"เสร็จสิ้น",i:"🟢",c:"sdn"},pending:{l:"รอชิ้นส่วน",i:"⚪",c:"spd"}};
const PM={Critical:{l:"Critical",i:"🔴",c:"pcr"},High:{l:"High",i:"🟠",c:"phi"},Medium:{l:"Medium",i:"🔵",c:"pme"},Low:{l:"Low",i:"🟢",c:"plo"}};
const sbadge=s=>{const x=SM[s]||SM.open;return `<span class="bdg b-${x.c}">${x.i} ${x.l}</span>`;};
const pbadge=p=>{const x=PM[p]||PM.Medium;return `<span class="bdg b-${x.c}">${x.i} ${x.l}</span>`;};
const fmtD=s=>s?s.split(" ")[0]:"—";

/* ══ SCREENS ════════════════════════════════════════════ */
function showScreen(id){
  ["scr-login","scr-user","scr-admin"].forEach(s=>{
    const el=document.getElementById(s);
    if(el) el.style.display=(s===id)?"block":"none";
  });
}
function showLogin(){ showScreen("scr-login"); }
function showUserPortal(){ showScreen("scr-user"); }
function showAdmin(){
  showScreen("scr-admin");
  applyRole(); loadDashboard(); loadTechs();
}

/* ══ AUTH ═══════════════════════════════════════════════ */
function selRole(r,el){
  loginRole=r;
  document.querySelectorAll(".rtab").forEach(t=>t.classList.remove("on"));
  el.classList.add("on");
  document.getElementById("pin-input").value="";
  document.getElementById("login-err").style.display="none";
  document.getElementById("pin-input").focus();
}
async function doLogin(){
  const pin=document.getElementById("pin-input").value;
  const errEl=document.getElementById("login-err");
  errEl.style.display="none";
  if(!pin){errEl.textContent="กรุณากรอก PIN";errEl.style.display="block";return;}
  try{
    const res=await fetch(BASE+"/api/auth/login",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({role:loginRole,pin})});
    const data=await res.json();
    if(!res.ok||!data.token){errEl.textContent=data.error||"PIN ไม่ถูกต้อง";errEl.style.display="block";return;}
    TOKEN=data.token;ROLE=data.role;USER=data.name;
    localStorage.setItem("cmms_token",TOKEN);
    localStorage.setItem("cmms_role",ROLE);
    localStorage.setItem("cmms_user",USER);
    document.getElementById("pin-input").value="";
    ["scr-login","scr-user"].forEach(s=>{const el=document.getElementById(s);if(el)el.style.display="none";});
    document.getElementById("scr-admin").style.display="block";
    applyRole(); loadDashboard(); loadTechs();
  }catch(e){errEl.textContent=e.message||"เชื่อมต่อไม่ได้";errEl.style.display="block";}
}
function doLogout(){
  TOKEN="";ROLE="";USER="";
  localStorage.removeItem("cmms_token");localStorage.removeItem("cmms_role");localStorage.removeItem("cmms_user");
  showLogin();
}
function applyRole(){
  const isAdmin=ROLE==="admin";
  const label=isAdmin?"🛠 Admin":"👷 Technician";
  document.getElementById("h-user").textContent=`${label} · ${USER}`;
  document.getElementById("h-cnt").textContent=ALL_TICKETS.length||"";
  document.querySelectorAll(".admin-only").forEach(el=>el.style.display=isAdmin?"":"none");
  document.querySelectorAll(".tech-visible").forEach(el=>el.style.display="");
  if(!isAdmin) document.querySelectorAll(".admin-only").forEach(el=>el.style.display="none");
}

/* ══ VIEWS ══════════════════════════════════════════════ */
function showView(v){
  if(v==="settings"&&ROLE!=="admin"){toast("⚠️ เฉพาะ Admin","warn");return;}
  document.querySelectorAll(".view").forEach(el=>{el.classList.remove("active");el.style.display="none";});
  const el=document.getElementById("view-"+v);
  if(el){el.classList.add("active");el.style.display="block";}
  document.querySelectorAll(".ni[id]").forEach(n=>n.classList.remove("on"));
  const nav=document.getElementById("nav-"+v);
  if(nav) nav.classList.add("on");
  closeDetail();
  const loaders={dashboard:loadDashboard,tickets:loadTickets,pm:loadPM,spare:loadSpare,kpi:loadKPI,settings:loadSettings,"tech-dash":loadTechDash,"new-ticket":renderNewTicket,"spare-txn":renderSpareTxn};
  if(loaders[v]) loaders[v]();
}

/* ══ DASHBOARD ══════════════════════════════════════════ */
async function loadDashboard(){
  try{
    const [stats,tickets]=await Promise.all([api("GET","/api/stats"),api("GET","/api/tickets")]);
    if(!stats||!tickets) return;
    ALL_TICKETS=tickets;
    document.getElementById("h-cnt").textContent=stats.all+" รายการ";
    document.getElementById("nc-open").textContent=stats.open+stats.inprog;
    document.getElementById("nc-all").textContent=stats.all;
    document.getElementById("nc-s-open").textContent=stats.open;
    document.getElementById("nc-s-ip").textContent=stats.inprog;
    document.getElementById("nc-s-done").textContent=stats.done;
    document.getElementById("nc-s-pd").textContent=stats.pending;
    // Low stock badge
    try{const low=await api("GET","/api/spare?low=1");if(low)document.getElementById("nc-low").textContent=low.length;}catch(_){}
    // Render
    const el=document.getElementById("view-dashboard");
    el.innerHTML=`
      <div class="sg">
        <div class="sc c1" onclick="filterStatus('all');showView('tickets')"><div class="sc-l">ทั้งหมด</div><div class="sc-v">${stats.all}</div><div class="sc-s">รายการในระบบ</div></div>
        <div class="sc c2" onclick="filterStatus('open');showView('tickets')"><div class="sc-l">รอดำเนินการ</div><div class="sc-v">${stats.open}</div><div class="sc-s">ต้องรีบดำเนินการ</div></div>
        <div class="sc c3" onclick="filterStatus('in-progress');showView('tickets')"><div class="sc-l">กำลังซ่อม</div><div class="sc-v">${stats.inprog}</div><div class="sc-s">อยู่ระหว่างดำเนินการ</div></div>
        <div class="sc c4" onclick="filterStatus('done');showView('tickets')"><div class="sc-l">เสร็จสิ้น</div><div class="sc-v">${stats.done}</div><div class="sc-s">ปิดงานแล้ว</div></div>
      </div>
      <div class="chart-row">
        <div class="chart-c"><div class="chart-t">📈 ใบแจ้งซ่อมรายเดือน</div><canvas id="chart-month" style="max-height:150px;"></canvas></div>
        <div class="chart-c"><div class="chart-t">🥧 ตามประเภท</div><canvas id="chart-type" style="max-height:150px;"></canvas></div>
        <div class="chart-c"><div class="chart-t">⚡ ตามระดับ</div><canvas id="chart-pri" style="max-height:150px;"></canvas></div>
      </div>
      <div class="tbar"><div class="tbar-t">รายการล่าสุด</div><button class="btn bg" onclick="showView('tickets')" style="font-size:12px;">ดูทั้งหมด →</button></div>
      <div class="tw">${buildTable(tickets.slice(0,8),false)}</div>`;
    drawCharts(stats);
  }catch(e){toast(e.message,"err");}
}

function drawCharts(s){
  Chart.defaults.color="#4a5568";
  Chart.defaults.font.family="IBM Plex Sans Thai";
  if(CHARTS.month) CHARTS.month.destroy();
  if(CHARTS.type)  CHARTS.type.destroy();
  if(CHARTS.pri)   CHARTS.pri.destroy();
  CHARTS.month=new Chart(document.getElementById("chart-month"),{type:"bar",data:{labels:s.byMonth.map(m=>m.month),datasets:[{label:"แจ้งซ่อม",data:s.byMonth.map(m=>m.total),backgroundColor:"rgba(0,200,255,.25)",borderColor:"rgba(0,200,255,.7)",borderWidth:1.5,borderRadius:3},{label:"เสร็จ",data:s.byMonth.map(m=>m.done),backgroundColor:"rgba(0,230,118,.2)",borderColor:"rgba(0,230,118,.65)",borderWidth:1.5,borderRadius:3}]},options:{responsive:true,plugins:{legend:{labels:{font:{size:10}}}},scales:{x:{grid:{color:"rgba(37,43,58,.4)"}},y:{grid:{color:"rgba(37,43,58,.4)"},ticks:{stepSize:1}}}}});
  const tc=["#00c8ff","#ff6030","#00e676","#ffcc00","#b060ff","#ff3b3b"];
  CHARTS.type=new Chart(document.getElementById("chart-type"),{type:"doughnut",data:{labels:s.byType.map(t=>t.type),datasets:[{data:s.byType.map(t=>t.n),backgroundColor:tc,borderWidth:0}]},options:{responsive:true,plugins:{legend:{position:"bottom",labels:{font:{size:10},padding:7,boxWidth:9}}}}});
  CHARTS.pri=new Chart(document.getElementById("chart-pri"),{type:"doughnut",data:{labels:["Critical","High","Medium","Low"],datasets:[{data:["Critical","High","Medium","Low"].map(p=>s.byPri.find(x=>x.priority===p)?.n||0),backgroundColor:["#ff3b3b","#ffaa00","#00c8ff","#00e676"],borderWidth:0}]},options:{responsive:true,plugins:{legend:{position:"bottom",labels:{font:{size:10},padding:7,boxWidth:9}}}}});
}

/* ══ TICKETS ════════════════════════════════════════════ */
async function loadTickets(){
  const q=document.getElementById("srch-inp")?.value||"";
  const type=document.getElementById("f-type")?.value||"";
  const pri=document.getElementById("f-pri")?.value||"";
  let url="/api/tickets?";
  if(FILTER_STATUS!=="all") url+="status="+FILTER_STATUS+"&";
  if(type) url+="type="+encodeURIComponent(type)+"&";
  if(pri)  url+="priority="+pri+"&";
  if(q)    url+="q="+encodeURIComponent(q);
  try{
    ALL_TICKETS=await api("GET",url)||[];
    const TYPES=["ไฟฟ้า","ประปา","เครื่องจักร","โครงสร้าง","แอร์/ระบบทำความเย็น","อื่นๆ"];
    document.getElementById("view-tickets").innerHTML=`
      <div class="tbar">
        <div class="tbar-t">รายการแจ้งซ่อม (${ALL_TICKETS.length})</div>
        <div class="srch"><span>🔍</span><input id="srch-inp" placeholder="ค้นหา..." oninput="loadTickets()"/></div>
        <select class="fsel" id="f-type" onchange="loadTickets()"><option value="">ประเภทฯ</option>${TYPES.map(t=>`<option>${t}</option>`).join("")}</select>
        <select class="fsel" id="f-pri" onchange="loadTickets()"><option value="">ระดับฯ</option><option>Critical</option><option>High</option><option>Medium</option><option>Low</option></select>
        <button class="btn bg" onclick="exportCSV()" style="font-size:12px;">⬇ CSV</button>
      </div>
      <div class="tw">${buildTable(ALL_TICKETS,true)}</div>`;
    applyRole();
  }catch(e){toast(e.message,"err");}
}

function filterStatus(s){FILTER_STATUS=s;}

function buildTable(list,showBtn){
  if(!list.length) return `<div class="emp"><div style="font-size:26px;margin-bottom:8px">📭</div><p>ไม่พบรายการ</p></div>`;
  return `<table><thead><tr><th>เลขที่</th><th>หัวข้อ</th><th>สถานที่</th><th>ประเภท</th><th>ระดับ</th><th>สถานะ</th><th>ช่าง</th><th>วันที่</th>${showBtn?"<th></th>":""}</tr></thead><tbody>${list.map(t=>`<tr onclick="openDetail('${t.id}')"><td><span class="tid">${t.id}</span>${!t.assigned_to?'<span class="newdot"></span>':""}</td><td style="max-width:155px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${t.title}</td><td style="color:var(--t2);font-size:12px">${t.location}</td><td><span class="bdg" style="background:var(--s2);color:var(--t2);border:1px solid var(--bd)">${t.type}</span></td><td>${pbadge(t.priority)}</td><td>${sbadge(t.status)}</td><td style="color:var(--t2);font-size:12px">${t.assigned_to||`<span style="color:var(--wn);font-size:11px">ยังไม่มอบหมาย</span>`}</td><td style="color:var(--t3);font-size:11px;font-family:var(--fm)">${fmtD(t.created_at)}</td>${showBtn?`<td><button class="btn bg" style="padding:3px 7px;font-size:11px" onclick="event.stopPropagation();openDetail('${t.id}')">ดู</button></td>`:""}</tr>`).join("")}</tbody></table>`;
}

/* ══ DETAIL PANEL ════════════════════════════════════════ */
async function openDetail(id){
  try{
    const t=await api("GET","/api/tickets/"+id);
    if(!t) return;
    CURRENT_TK=t;
    document.getElementById("dp-id").textContent=t.id;
    document.getElementById("dp-title").textContent=t.title;
    const isAdmin=ROLE==="admin";
    document.getElementById("dp-info").innerHTML=`
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:12px;">
        <div class="dr"><div class="dk">สถานะ</div>${sbadge(t.status)}</div>
        <div class="dr"><div class="dk">ระดับ</div>${pbadge(t.priority)}</div>
        <div class="dr"><div class="dk">ประเภท</div><div class="dv">${t.type}</div></div>
        <div class="dr"><div class="dk">สถานที่</div><div class="dv">${t.location}</div></div>
        <div class="dr"><div class="dk">ผู้แจ้ง</div><div class="dv">${t.reporter}${t.phone?` <span style="color:var(--t2);font-size:11px">${t.phone}</span>`:""}</div></div>
        <div class="dr"><div class="dk">ช่าง</div><div class="dv">${t.assigned_to||`<span style="color:var(--wn)">ยังไม่มอบหมาย</span>`}</div></div>
        <div class="dr"><div class="dk">วันที่แจ้ง</div><div class="dv">${fmtD(t.created_at)}</div></div>
        <div class="dr"><div class="dk">กำหนดเสร็จ</div><div class="dv">${t.due_date||"—"}</div></div>
      </div>
      <div class="dr" style="margin-bottom:12px;"><div class="dk">รายละเอียด</div><div class="ddc">${t.description}</div></div>
      ${isAdmin?`<hr class="div"/>
      <div class="dk" style="margin-bottom:7px;">มอบหมายช่าง</div>
      <div style="display:flex;gap:7px;margin-bottom:10px;">
        <select class="fsel" id="dp-assign" style="flex:1;font-size:12px;"><option value="">-- เลือกช่าง --</option>${TECHS.map(t=>`<option${t.name===CURRENT_TK?.assigned_to?" selected":""}>${t.name}</option>`).join("")}</select>
        <button class="btn bg" style="font-size:12px;" onclick="doAssign()">บันทึก</button>
      </div>
      <div class="dk" style="margin-bottom:7px;">กำหนดเสร็จ</div>
      <div style="display:flex;gap:7px;">
        <input type="date" class="fi" id="dp-due-edit" value="${t.due_date||""}" style="flex:1;font-size:12px;"/>
        <button class="btn bg" style="font-size:12px;" onclick="doDue()">บันทึก</button>
      </div>`:""}`;
    document.getElementById("dp-tl").innerHTML=buildTL(t.timeline||[]);
    document.getElementById("dp-comment").innerHTML=`
      <div class="fgg" style="margin-bottom:10px;"><label class="lbl">เพิ่มบันทึก</label><textarea class="fi" id="dp-comment-txt" placeholder="พิมพ์ข้อความ..." style="min-height:70px;"></textarea></div>
      <button class="btn bp" onclick="doComment()" style="font-size:12px;margin-bottom:12px;">💬 บันทึก</button>
      <hr class="div"/><div class="dk" style="margin-bottom:9px;">ประวัติ</div>
      <ul class="tl">${buildTLItems(t.timeline||[])}</ul>`;
    document.getElementById("detail-panel").style.display="flex";
    dpTab("info",document.querySelector(".dtb"));
  }catch(e){toast(e.message,"err");}
}

function closeDetail(){document.getElementById("detail-panel").style.display="none";CURRENT_TK=null;}
function dpTab(tab,el){
  document.querySelectorAll(".dtb").forEach(d=>d.classList.remove("on"));
  if(el) el.classList.add("on");
  ["dp-info","dp-tl","dp-comment"].forEach(id=>document.getElementById(id).style.display="none");
  document.getElementById("dp-"+tab).style.display="block";
}

function buildTL(items){return `<ul class="tl">${buildTLItems(items)}</ul>`;}
function buildTLItems(items){return (items||[]).map(e=>`<li class="tl-li"><div class="tl-d tl-${e.type||"acc"}"></div><div><div class="tl-at">${e.created_at||e.at||""}${e.author?`<span class="tl-by"> · ${e.author}</span>`:""}</div><div class="tl-msg">${e.message||e.msg||""}</div></div></li>`).join("");}

async function setStatus(s){
  if(!CURRENT_TK) return;
  try{
    const t=await api("PATCH","/api/tickets/"+CURRENT_TK.id+"/status",{status:s});
    if(!t) return;
    CURRENT_TK=t;
    document.getElementById("dp-tl").innerHTML=buildTL(t.timeline);
    toast(s==="done"?"✅ ปิดงานแล้ว":"🔧 อัปเดตสถานะแล้ว");
    loadDashboard();
  }catch(e){toast(e.message,"err");}
}
async function doAssign(){
  if(!CURRENT_TK) return;
  const tech=document.getElementById("dp-assign").value;
  try{const t=await api("PATCH","/api/tickets/"+CURRENT_TK.id+"/assign",{assigned_to:tech});if(!t)return;CURRENT_TK=t;toast("✅ มอบหมายแล้ว");openDetail(CURRENT_TK.id);}catch(e){toast(e.message,"err");}
}
async function doDue(){
  if(!CURRENT_TK) return;
  const due=document.getElementById("dp-due-edit").value;
  try{const t=await api("PATCH","/api/tickets/"+CURRENT_TK.id+"/assign",{due_date:due});if(!t)return;CURRENT_TK=t;toast("📅 อัปเดตวันกำหนดแล้ว");}catch(e){toast(e.message,"err");}
}
async function doComment(){
  if(!CURRENT_TK) return;
  const msg=document.getElementById("dp-comment-txt")?.value?.trim();
  if(!msg) return;
  try{const r=await api("POST","/api/tickets/"+CURRENT_TK.id+"/comment",{message:msg});if(!r)return;document.getElementById("dp-comment-txt").value="";document.querySelector("#dp-comment .tl").innerHTML=buildTLItems(r.timeline);toast("💬 บันทึกแล้ว");}catch(e){toast(e.message,"err");}
}
async function doDelete(){
  if(!CURRENT_TK||!confirm("ลบ "+CURRENT_TK.id+" ?")) return;
  try{await api("DELETE","/api/tickets/"+CURRENT_TK.id);closeDetail();toast("🗑 ลบแล้ว","warn");loadDashboard();loadTickets();}catch(e){toast(e.message,"err");}
}

/* ══ NEW TICKET ══════════════════════════════════════════ */
function renderNewTicket(){
  const TYPES=["ไฟฟ้า","ประปา","เครื่องจักร","โครงสร้าง","แอร์/ระบบทำความเย็น","อื่นๆ"];
  document.getElementById("view-new-ticket").innerHTML=`
    <div class="fc">
      <div class="fc-t">✏️ แจ้งซ่อมใหม่</div>
      <div class="fc-s">กรอกข้อมูลที่มี <span style="color:var(--rd)">*</span> ให้ครบ</div>
      <div class="err-box" id="af-err" style="display:none;"></div>
      <div class="fg2">
        <div class="fgg"><label class="lbl">ชื่อผู้แจ้ง <span class="req">*</span></label><input class="fi" id="af-reporter" placeholder="ชื่อ-นามสกุล"/></div>
        <div class="fgg"><label class="lbl">แผนก</label><input class="fi" id="af-dept"/></div>
        <div class="fgg"><label class="lbl">สถานที่ <span class="req">*</span></label><input class="fi" id="af-loc" placeholder="อาคาร/ชั้น/ห้อง"/></div>
        <div class="fgg"><label class="lbl">เบอร์ติดต่อ</label><input class="fi" id="af-phone" type="tel"/></div>
        <div class="fgg full"><label class="lbl">หัวข้อปัญหา <span class="req">*</span></label><input class="fi" id="af-title" placeholder="สรุปปัญหาสั้นๆ"/></div>
        <div class="fgg"><label class="lbl">ประเภทงาน <span class="req">*</span></label><select class="fi" id="af-type"><option value="">-- เลือก --</option>${TYPES.map(t=>`<option>${t}</option>`).join("")}</select></div>
        <div class="fgg"><label class="lbl">ระดับ <span class="req">*</span></label><select class="fi" id="af-pri"><option value="">-- เลือก --</option><option>Critical</option><option>High</option><option>Medium</option><option>Low</option></select></div>
        <div class="fgg full"><label class="lbl">รายละเอียด <span class="req">*</span></label><textarea class="fi" id="af-desc"></textarea></div>
        <div class="fgg"><label class="lbl">มอบหมายช่าง</label><select class="fi" id="af-tech"><option value="">-- เลือกช่าง --</option>${TECHS.map(t=>`<option>${t.name}</option>`).join("")}</select></div>
        <div class="fgg"><label class="lbl">กำหนดเสร็จ</label><input class="fi" id="af-due" type="date"/></div>
      </div>
      <div class="fa">
        <button class="btn bg" onclick="showView('dashboard')">ยกเลิก</button>
        <button class="btn bp" onclick="submitAdminForm()">📨 ส่งใบแจ้งซ่อม</button>
      </div>
    </div>`;
}
async function submitAdminForm(){
  const f={title:document.getElementById("af-title").value.trim(),reporter:document.getElementById("af-reporter").value.trim(),location:document.getElementById("af-loc").value.trim(),type:document.getElementById("af-type").value,priority:document.getElementById("af-pri").value,description:document.getElementById("af-desc").value.trim(),phone:document.getElementById("af-phone").value,dept:document.getElementById("af-dept").value,assigned_to:document.getElementById("af-tech").value,due_date:document.getElementById("af-due").value};
  const miss=["title","reporter","location","type","priority","description"].filter(k=>!f[k]);
  const errEl=document.getElementById("af-err");
  if(miss.length){errEl.textContent="⚠️ กรุณากรอก: "+miss.join(", ");errEl.style.display="block";return;}
  errEl.style.display="none";
  try{const t=await api("POST","/api/tickets",f);if(!t)return;toast("✅ ส่งใบแจ้งซ่อม "+t.id+" แล้ว");showView("dashboard");}catch(e){errEl.textContent=e.message;errEl.style.display="block";}
}

/* ══ PM ══════════════════════════════════════════════════ */
async function loadPM(){
  const pms=await api("GET","/api/pm")||[];
  document.getElementById("nc-pm").textContent=pms.length;
  document.getElementById("view-pm").innerHTML=`
    <div class="tbar"><div class="tbar-t">แผนซ่อมบำรุงเชิงป้องกัน (PM)</div><button class="btn bp admin-only" onclick="openPMModal(null)" style="font-size:12px;">＋ เพิ่มแผน</button></div>
    <div class="pm-g">${!pms.length?`<div class="emp" style="grid-column:1/-1"><div style="font-size:26px;margin-bottom:8px">📋</div><p>ยังไม่มีแผน PM</p></div>`:pms.map(p=>`<div class="pm-c" onclick="${ROLE==="admin"?`openPMModal('${p.id}')`:""};event.stopPropagation()">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">
        <div><div style="font-size:13px;font-weight:700;margin-bottom:2px">${p.name}</div><div style="font-size:11px;color:var(--t3);font-family:var(--fm)">📍 ${p.location}</div></div>
        <span class="bdg" style="background:var(--s2);color:var(--ac);border:1px solid rgba(0,200,255,.18)">${p.frequency}</span>
      </div>
      <div style="font-size:11px;color:var(--t2);margin-bottom:2px">ครั้งถัดไป: <b style="color:var(--ac)">${p.next_date}</b></div>
      <div class="pm-bg"><div class="pm-bf" style="width:${p.progress||0}%"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--t3)">
        <span>🔧 ${p.technician||"ยังไม่ระบุ"}</span>
        <div style="display:flex;align-items:center;gap:7px;">
          <span style="font-family:var(--fm)">${p.progress||0}%</span>
          ${ROLE==="admin"?`<span class="ico d" style="width:20px;height:20px;font-size:11px;" onclick="event.stopPropagation();if(!confirm('ลบ?'))return;api('DELETE','/api/pm/${p.id}').then(()=>{toast('🗑 ลบแล้ว','warn');loadPM();})">×</span>`:""}
        </div>
      </div>
    </div>`).join("")}</div>`;
  applyRole();
}

function openPMModal(id){
  openModal(id?"แก้ไขแผน PM":"เพิ่มแผน PM","",`
    <div class="fg2">
      <div class="fgg full"><label class="lbl">ชื่อแผน *</label><input class="fi" id="pm-name" placeholder="เช่น ตรวจสอบระบบไฟฟ้า"/></div>
      <div class="fgg"><label class="lbl">สถานที่</label><input class="fi" id="pm-loc"/></div>
      <div class="fgg"><label class="lbl">ความถี่</label><select class="fi" id="pm-freq">${["ทุก 1 สัปดาห์","ทุก 2 สัปดาห์","ทุก 1 เดือน","ทุก 3 เดือน","ทุก 6 เดือน","ทุก 1 ปี"].map(f=>`<option>${f}</option>`).join("")}</select></div>
      <div class="fgg"><label class="lbl">วันที่ครั้งถัดไป *</label><input class="fi" id="pm-next" type="date"/></div>
      <div class="fgg"><label class="lbl">ช่าง</label><select class="fi" id="pm-tech"><option value="">-- เลือก --</option>${TECHS.map(t=>`<option>${t.name}</option>`).join("")}</select></div>
      <div class="fgg"><label class="lbl">ความคืบหน้า (%)</label><div style="display:flex;gap:8px;align-items:center;margin-top:5px;"><input type="range" min="0" max="100" value="0" id="pm-prog" oninput="document.getElementById('pm-prog-v').textContent=this.value+'%'" style="flex:1"/><span id="pm-prog-v" style="font-family:var(--fm);font-size:13px;min-width:36px;text-align:right">0%</span></div></div>
    </div>`,
    `<button class="btn bg" onclick="closeModal()">ยกเลิก</button><button class="btn bp" onclick="savePM('${id||""}')">บันทึก</button>`
  );
}
async function savePM(id){
  const d={name:document.getElementById("pm-name").value.trim(),location:document.getElementById("pm-loc").value||"ทั่วไป",frequency:document.getElementById("pm-freq").value,next_date:document.getElementById("pm-next").value,technician:document.getElementById("pm-tech").value,progress:+document.getElementById("pm-prog").value};
  if(!d.name||!d.next_date){toast("กรอกข้อมูลให้ครบ","err");return;}
  try{
    if(id) await api("PUT","/api/pm/"+id,d); else await api("POST","/api/pm",d);
    toast("📋 บันทึกแล้ว");closeModal();loadPM();
  }catch(e){toast(e.message,"err");}
}

/* ══ SPARE PARTS ═════════════════════════════════════════ */
async function loadSpare(){
  const srch=document.getElementById("spare-srch")?.value||"";
  const cat=document.getElementById("spare-cat")?.value||"";
  let url="/api/spare?";
  if(srch) url+="q="+encodeURIComponent(srch)+"&";
  if(cat)  url+="category="+encodeURIComponent(cat)+"&";
  try{
    ALL_SPARE=await api("GET",url)||[];
    const cats=["ไฟฟ้า","ระบบน้ำ","เครื่องจักร","แอร์","โครงสร้าง","ทั่วไป"];
    const low=ALL_SPARE.filter(p=>p.qty<=p.min_qty).length;
    const totalVal=ALL_SPARE.reduce((a,p)=>a+p.qty*p.price,0);
    document.getElementById("nc-low").textContent=low;
    document.getElementById("view-spare").innerHTML=`
      <div class="sg" style="grid-template-columns:repeat(3,1fr);">
        <div class="sc c1"><div class="sc-l">รายการทั้งหมด</div><div class="sc-v">${ALL_SPARE.length}</div><div class="sc-s">รายการในคลัง</div></div>
        <div class="sc c3"><div class="sc-l">สต็อกต่ำกว่ากำหนด</div><div class="sc-v">${low}</div><div class="sc-s">ต้องสั่งซื้อ</div></div>
        <div class="sc c4"><div class="sc-l">มูลค่าคลังรวม</div><div class="sc-v" style="font-size:18px">${totalVal.toLocaleString()} ฿</div><div class="sc-s">ราคาทุน</div></div>
      </div>
      <div class="tbar">
        <div class="tbar-t">คลังอะไหล่</div>
        <div class="srch"><span>🔍</span><input id="spare-srch" placeholder="ค้นหา..." oninput="loadSpare()"/></div>
        <select class="fsel" id="spare-cat" onchange="loadSpare()"><option value="">หมวดหมู่ทั้งหมด</option>${cats.map(c=>`<option>${c}</option>`).join("")}</select>
        <button class="btn bg admin-only" onclick="loadSpare()" style="font-size:12px;">🔄</button>
        <button class="btn bp admin-only" onclick="openSpareModal(null)" style="font-size:12px;">＋ เพิ่มอะไหล่</button>
      </div>
      <div class="spare-grid">${ALL_SPARE.map(p=>{
        const isLow=p.qty<=p.min_qty;
        const isCrit=p.qty===0;
        const pct=p.min_qty>0?Math.min(100,Math.round(p.qty/p.min_qty*100)):100;
        const barColor=isCrit?"#ff3b3b":isLow?"#ffaa00":"#00c8ff";
        return `<div class="spare-c${isLow?" low":""}${isCrit?" critical":""}" onclick="openSpareDetail('${p.id}')">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
            <div style="font-size:13px;font-weight:700;">${p.name}</div>
            <span class="bdg" style="background:var(--s2);color:var(--t2);border:1px solid var(--bd)">${p.category}</span>
          </div>
          <div style="font-size:11px;color:var(--t3);font-family:var(--fm);margin-bottom:8px;">${p.code||"—"} · ${p.location||"—"}</div>
          <div style="display:flex;align-items:baseline;gap:4px;">
            <span class="spare-qty" style="color:${isCrit?"var(--rd)":isLow?"var(--wn)":"var(--ac)"}">${p.qty}</span>
            <span class="spare-unit">${p.unit}</span>
            <span style="margin-left:auto;font-size:11px;color:var(--t3)">min: ${p.min_qty}</span>
          </div>
          <div class="qty-bar-bg"><div class="qty-bar-fill" style="width:${pct}%;background:${barColor}"></div></div>
          <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--t3);margin-top:5px;">
            <span>${p.price.toLocaleString()} ฿/${p.unit}</span>
            ${isCrit?`<span style="color:var(--rd);font-weight:700">⚠️ หมด</span>`:isLow?`<span style="color:var(--wn);font-weight:700">⚠️ ใกล้หมด</span>`:`<span style="color:var(--ok)">✓ ปกติ</span>`}
          </div>
        </div>`}).join("")||`<div class="emp" style="grid-column:1/-1"><div style="font-size:26px;margin-bottom:8px">🗃️</div><p>ไม่พบรายการ</p></div>`}</div>`;
    applyRole();
  }catch(e){toast(e.message,"err");}
}

async function openSpareDetail(id){
  try{
    const p=await api("GET","/api/spare/"+id);
    if(!p) return;
    const isLow=p.qty<=p.min_qty;
    document.getElementById("sdm-title").textContent=p.name;
    document.getElementById("sdm-body").innerHTML=`
      <div class="sg" style="grid-template-columns:repeat(3,1fr);padding:0;margin-bottom:14px;">
        <div class="sc c1" style="cursor:default"><div class="sc-l">คงเหลือ</div><div class="sc-v" style="color:${p.qty===0?"var(--rd)":isLow?"var(--wn)":"var(--ac)"}">${p.qty}</div><div class="sc-s">${p.unit}</div></div>
        <div class="sc c2" style="cursor:default"><div class="sc-l">ขั้นต่ำ</div><div class="sc-v">${p.min_qty}</div><div class="sc-s">${p.unit}</div></div>
        <div class="sc c4" style="cursor:default"><div class="sc-l">มูลค่ารวม</div><div class="sc-v" style="font-size:16px">${(p.qty*p.price).toLocaleString()}</div><div class="sc-s">บาท</div></div>
      </div>
      <div class="fg2" style="margin-bottom:14px;">
        <div class="dr"><div class="dk">รหัส</div><div class="dv" style="font-family:var(--fm)">${p.code||"—"}</div></div>
        <div class="dr"><div class="dk">หมวดหมู่</div><div class="dv">${p.category}</div></div>
        <div class="dr"><div class="dk">ที่เก็บ</div><div class="dv">${p.location||"—"}</div></div>
        <div class="dr"><div class="dk">ซัพพลายเออร์</div><div class="dv">${p.supplier||"—"}</div></div>
        <div class="dr"><div class="dk">ราคา/หน่วย</div><div class="dv">${p.price.toLocaleString()} ฿</div></div>
        <div class="dr"><div class="dk">อัปเดตล่าสุด</div><div class="dv" style="font-size:12px">${fmtD(p.updated_at)}</div></div>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:14px;">
        <button class="btn bp" style="flex:1;font-size:12px;" onclick="openWithdrawModal('${p.id}','${p.name}',${p.qty},'${p.unit}')">📤 เบิกอะไหล่</button>
        <button class="btn bok" style="flex:1;font-size:12px;" onclick="openReceiveModal('${p.id}','${p.name}','${p.unit}')">📥 รับเข้าคลัง</button>
        ${ROLE==="admin"?`<button class="btn bg" style="font-size:12px;" onclick="openSpareModal('${p.id}')">✏️</button><button class="btn bdl" style="font-size:12px;" onclick="if(!confirm('ลบ?'))return;api('DELETE','/api/spare/${p.id}').then(()=>{document.getElementById('spare-detail-modal').style.display='none';toast('🗑 ลบแล้ว','warn');loadSpare();})">🗑</button>`:""}
      </div>
      <div class="chart-t">ประวัติการเคลื่อนไหว</div>
      <table style="width:100%;border-collapse:collapse;">
        <thead><tr><th style="text-align:left;padding:6px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd);">วันที่</th><th style="text-align:left;padding:6px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd);">ประเภท</th><th style="text-align:right;padding:6px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd);">จำนวน</th><th style="text-align:left;padding:6px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd);">หมายเหตุ</th><th style="text-align:left;padding:6px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd);">โดย</th></tr></thead>
        <tbody>${(p.transactions||[]).map(t=>`<tr style="border-bottom:1px solid rgba(37,43,58,.4)"><td style="padding:6px;font-size:11px;color:var(--t3);font-family:var(--fm)">${fmtD(t.created_at)}</td><td style="padding:6px;font-size:12px">${t.type==="in"?`<span style="color:var(--ok)">📥 รับเข้า</span>`:`<span style="color:var(--a2)">📤 เบิก</span>`}</td><td style="padding:6px;font-size:13px;font-family:var(--fm);text-align:right;font-weight:700;color:${t.type==="in"?"var(--ok)":"var(--a2)"}">${t.type==="in"?"+":"-"}${t.qty}</td><td style="padding:6px;font-size:12px;color:var(--t2)">${t.note||"—"}</td><td style="padding:6px;font-size:11px;color:var(--t3)">${t.by||"—"}</td></tr>`).join("")||`<tr><td colspan="5" style="padding:16px;text-align:center;color:var(--t3)">ไม่มีประวัติ</td></tr>`}</tbody>
      </table>`;
    document.getElementById("spare-detail-modal").style.display="flex";
  }catch(e){toast(e.message,"err");}
}

function openWithdrawModal(id,name,maxQty,unit){
  openModal(`📤 เบิกอะไหล่: ${name}`,`คงเหลือ: ${maxQty} ${unit}`,`
    <div class="fg2">
      <div class="fgg"><label class="lbl">จำนวนที่เบิก *</label><input class="fi" id="txn-qty" type="number" min="1" max="${maxQty}" value="1" placeholder="จำนวน"/></div>
      <div class="fgg"><label class="lbl">เลขที่ใบแจ้งซ่อม</label><input class="fi" id="txn-ticket" placeholder="WO-0000 (ถ้ามี)" style="font-family:var(--fm)" oninput="this.value=this.value.toUpperCase()"/></div>
      <div class="fgg full"><label class="lbl">หมายเหตุ</label><input class="fi" id="txn-note" placeholder="หมายเหตุการเบิก (ถ้ามี)"/></div>
    </div>`,
    `<button class="btn bg" onclick="closeModal()">ยกเลิก</button><button class="btn bu" onclick="doWithdraw('${id}')">📤 ยืนยันเบิก</button>`
  );
}
async function doWithdraw(id){
  const qty=+document.getElementById("txn-qty").value;
  const ticket=document.getElementById("txn-ticket").value;
  const note=document.getElementById("txn-note").value;
  if(!qty||qty<=0){toast("ระบุจำนวนที่ถูกต้อง","err");return;}
  try{await api("POST","/api/spare/"+id+"/withdraw",{qty,ticket_id:ticket,note});toast("✅ เบิกอะไหล่แล้ว "+qty+" ชิ้น");closeModal();document.getElementById("spare-detail-modal").style.display="none";loadSpare();}catch(e){toast(e.message,"err");}
}

function openReceiveModal(id,name,unit){
  openModal(`📥 รับอะไหล่เข้าคลัง: ${name}`,"",`
    <div class="fg2">
      <div class="fgg"><label class="lbl">จำนวนที่รับ *</label><input class="fi" id="recv-qty" type="number" min="1" value="1"/></div>
      <div class="fgg full"><label class="lbl">หมายเหตุ</label><input class="fi" id="recv-note" placeholder="เช่น รับจากซัพพลายเออร์ (ถ้ามี)"/></div>
    </div>`,
    `<button class="btn bg" onclick="closeModal()">ยกเลิก</button><button class="btn bok" onclick="doReceive('${id}')">📥 ยืนยันรับเข้า</button>`
  );
}
async function doReceive(id){
  const qty=+document.getElementById("recv-qty").value;
  const note=document.getElementById("recv-note").value;
  if(!qty||qty<=0){toast("ระบุจำนวนที่ถูกต้อง","err");return;}
  try{await api("POST","/api/spare/"+id+"/receive",{qty,note});toast("✅ รับอะไหล่เข้าคลังแล้ว +"+qty);closeModal();document.getElementById("spare-detail-modal").style.display="none";loadSpare();}catch(e){toast(e.message,"err");}
}

function openSpareModal(id){
  openModal(id?"แก้ไขอะไหล่":"เพิ่มอะไหล่ใหม่","",`
    <div class="fg2">
      <div class="fgg full"><label class="lbl">ชื่ออะไหล่ *</label><input class="fi" id="sp-name" placeholder="ชื่ออะไหล่"/></div>
      <div class="fgg"><label class="lbl">รหัสอะไหล่</label><input class="fi" id="sp-code" placeholder="เช่น LED-18W"/></div>
      <div class="fgg"><label class="lbl">หมวดหมู่ *</label><select class="fi" id="sp-cat">${["ไฟฟ้า","ระบบน้ำ","เครื่องจักร","แอร์","โครงสร้าง","ทั่วไป"].map(c=>`<option>${c}</option>`).join("")}</select></div>
      <div class="fgg"><label class="lbl">หน่วย *</label><input class="fi" id="sp-unit" placeholder="เช่น ชิ้น, เมตร, ลิตร" value="ชิ้น"/></div>
      <div class="fgg"><label class="lbl">จำนวนเริ่มต้น</label><input class="fi" id="sp-qty" type="number" min="0" value="0"/></div>
      <div class="fgg"><label class="lbl">จำนวนขั้นต่ำ</label><input class="fi" id="sp-minqty" type="number" min="0" value="5"/></div>
      <div class="fgg"><label class="lbl">ราคา/หน่วย (฿)</label><input class="fi" id="sp-price" type="number" min="0" value="0" step="0.01"/></div>
      <div class="fgg"><label class="lbl">ที่เก็บ</label><input class="fi" id="sp-loc" placeholder="เช่น ชั้น A1"/></div>
      <div class="fgg full"><label class="lbl">ซัพพลายเออร์</label><input class="fi" id="sp-supplier" placeholder="ชื่อซัพพลายเออร์"/></div>
    </div>`,
    `<button class="btn bg" onclick="closeModal()">ยกเลิก</button><button class="btn bp" onclick="saveSpare('${id||""}')">บันทึก</button>`
  );
}
async function saveSpare(id){
  const d={name:document.getElementById("sp-name").value.trim(),code:document.getElementById("sp-code").value,category:document.getElementById("sp-cat").value,unit:document.getElementById("sp-unit").value,qty:+document.getElementById("sp-qty").value,min_qty:+document.getElementById("sp-minqty").value,price:+document.getElementById("sp-price").value,location:document.getElementById("sp-loc").value,supplier:document.getElementById("sp-supplier").value};
  if(!d.name||!d.category||!d.unit){toast("กรอกข้อมูลให้ครบ","err");return;}
  try{
    if(id) await api("PUT","/api/spare/"+id,d); else await api("POST","/api/spare",d);
    toast("✅ บันทึกอะไหล่แล้ว");closeModal();loadSpare();
  }catch(e){toast(e.message,"err");}
}

/* ══ SPARE TXN (Tech) ════════════════════════════════════ */
function renderSpareTxn(){
  document.getElementById("view-spare-txn").innerHTML=`
    <div class="tbar"><div class="tbar-t">📦 เบิก/รับอะไหล่</div></div>
    <div style="max-width:600px;margin:0 auto;padding:14px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-bottom:14px;">
        <div class="tdc" onclick="loadSpare();showView('spare')" style="cursor:pointer;background:rgba(0,200,255,.05);border-color:rgba(0,200,255,.2)">
          <div style="font-size:32px;margin-bottom:8px;">🗃️</div>
          <h3 style="color:var(--ac);">ดูคลังอะไหล่</h3>
          <p style="font-size:12px;color:var(--t2);margin-top:4px;">ดูสต็อก ค้นหา และเบิกอะไหล่</p>
        </div>
        <div class="tdc" style="background:rgba(0,230,118,.05);border-color:rgba(0,230,118,.2)">
          <div style="font-size:32px;margin-bottom:8px;">📥</div>
          <h3 style="color:var(--ok);">รับอะไหล่</h3>
          <p style="font-size:12px;color:var(--t2);margin-top:4px;">บันทึกการรับอะไหล่เข้าคลัง</p>
        </div>
      </div>
      <div class="sec-c">
        <div class="sec-h"><h3>🔍 ค้นหาอะไหล่เพื่อเบิก/รับ</h3></div>
        <div class="sec-b">
          <div style="display:flex;gap:8px;margin-bottom:12px;">
            <input class="fi" id="st-srch" style="flex:1" placeholder="ชื่อหรือรหัสอะไหล่..." oninput="searchSpareTxn()"/>
          </div>
          <div id="st-results"></div>
        </div>
      </div>
    </div>`;
}

async function searchSpareTxn(){
  const q=document.getElementById("st-srch").value;
  if(!q){document.getElementById("st-results").innerHTML="";return;}
  try{
    const parts=await api("GET","/api/spare?q="+encodeURIComponent(q));
    document.getElementById("st-results").innerHTML=`<table style="width:100%;border-collapse:collapse;">${parts.map(p=>`<tr style="border-bottom:1px solid rgba(37,43,58,.4)"><td style="padding:8px;font-size:13px">${p.name}</td><td style="padding:8px;font-family:var(--fm);font-size:13px;color:${p.qty<=p.min_qty?"var(--wn)":"var(--ac)"};">${p.qty} ${p.unit}</td><td style="padding:8px"><div style="display:flex;gap:6px;"><button class="btn bu" style="font-size:11px;padding:4px 8px;" onclick="openWithdrawModal('${p.id}','${p.name}',${p.qty},'${p.unit}')">📤 เบิก</button><button class="btn bok" style="font-size:11px;padding:4px 8px;" onclick="openReceiveModal('${p.id}','${p.name}','${p.unit}')">📥 รับ</button></div></td></tr>`).join("")||`<tr><td colspan="3" style="padding:16px;text-align:center;color:var(--t3)">ไม่พบอะไหล่</td></tr>`}</table>`;
  }catch(e){toast(e.message,"err");}
}

/* ══ KPI ═════════════════════════════════════════════════ */
async function loadKPI(){
  try{
    const kpi=await api("GET","/api/kpi");
    if(!kpi) return;
    const settings=await api("GET","/api/settings").catch(()=>({}));
    const mttrTarget=+(settings?.kpi_mttr_target||4);
    const compTarget=+(settings?.kpi_completion||90);
    const mttrOk=kpi.mttr<=mttrTarget||kpi.mttr===0;
    const compOk=kpi.compRate>=compTarget;
    document.getElementById("view-kpi").innerHTML=`
      <div class="kpi-grid">
        <div class="kpi-c">
          <div class="kpi-l">MTTR (เวลาซ่อมเฉลี่ย)</div>
          <div class="kpi-v" style="color:${mttrOk?"var(--ok)":"var(--rd)"}">${kpi.mttr||0}<span style="font-size:14px;color:var(--t2);margin-left:4px;">ชม.</span></div>
          <div class="kpi-t">เป้าหมาย ≤ ${mttrTarget} ชม. · ${mttrOk?"✅ ดีกว่าเป้า":"⚠️ เกินเป้า"}</div>
          <div class="prog-bar-bg"><div class="prog-bar" style="width:${Math.min(100,mttrTarget>0?kpi.mttr/mttrTarget*100:0)}%;background:${mttrOk?"var(--ok)":"var(--rd)"}"></div></div>
        </div>
        <div class="kpi-c">
          <div class="kpi-l">อัตราเสร็จงาน</div>
          <div class="kpi-v" style="color:${compOk?"var(--ok)":"var(--wn)"}">${kpi.compRate}<span style="font-size:14px;color:var(--t2);margin-left:2px;">%</span></div>
          <div class="kpi-t">เป้าหมาย ≥ ${compTarget}% · ${compOk?"✅ บรรลุเป้า":"⚠️ ต่ำกว่าเป้า"}</div>
          <div class="prog-bar-bg"><div class="prog-bar" style="width:${kpi.compRate}%;background:${compOk?"var(--ok)":"var(--wn)"}"></div></div>
        </div>
        <div class="kpi-c">
          <div class="kpi-l">งานเกินกำหนด</div>
          <div class="kpi-v" style="color:${kpi.overdue===0?"var(--ok)":kpi.overdue<=3?"var(--wn)":"var(--rd)"}">${kpi.overdue}<span style="font-size:14px;color:var(--t2);margin-left:4px;">รายการ</span></div>
          <div class="kpi-t">จาก ${kpi.total} รายการทั้งหมด</div>
          <div class="prog-bar-bg"><div class="prog-bar" style="width:${kpi.total>0?kpi.overdue/kpi.total*100:0}%;background:${kpi.overdue===0?"var(--ok)":"var(--rd)"}"></div></div>
        </div>
      </div>
      <div class="kpi-row">
        <div class="kpi-chart-c">
          <div class="chart-t">📊 อัตราเสร็จรายเดือน</div>
          <canvas id="kpi-monthly" style="max-height:180px;"></canvas>
        </div>
        <div class="kpi-chart-c">
          <div class="chart-t">👷 ประสิทธิภาพช่างแต่ละคน</div>
          <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr><th style="text-align:left;padding:7px 8px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd)">ช่าง</th><th style="text-align:center;padding:7px 8px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd)">รับงาน</th><th style="text-align:center;padding:7px 8px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd)">เสร็จ</th><th style="text-align:center;padding:7px 8px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd)">อัตรา</th><th style="text-align:center;padding:7px 8px;font-size:10px;color:var(--t3);letter-spacing:.08em;border-bottom:1px solid var(--bd)">เวลาเฉลี่ย</th></tr></thead>
              <tbody>${kpi.techPerf.map(t=>{const rate=t.total>0?Math.round(t.done/t.total*100):0;return `<tr style="border-bottom:1px solid rgba(37,43,58,.4)"><td style="padding:7px 8px;font-size:13px">${t.tech}</td><td style="padding:7px 8px;font-size:13px;font-family:var(--fm);text-align:center">${t.total}</td><td style="padding:7px 8px;font-size:13px;font-family:var(--fm);text-align:center;color:var(--ok)">${t.done}</td><td style="padding:7px 8px;text-align:center"><div style="background:var(--bg);border-radius:4px;height:4px;overflow:hidden;width:60px;margin:0 auto"><div style="height:100%;background:${rate>=80?"var(--ok)":rate>=60?"var(--wn)":"var(--rd)"};width:${rate}%"></div></div><div style="font-size:11px;font-family:var(--fm);text-align:center;margin-top:2px">${rate}%</div></td><td style="padding:7px 8px;font-size:12px;font-family:var(--fm);text-align:center;color:var(--t2)">${t.avg_hrs?Math.round(t.avg_hrs*10)/10+" ชม.":"—"}</td></tr>`;}).join("")||`<tr><td colspan="5" style="padding:16px;text-align:center;color:var(--t3)">ยังไม่มีข้อมูล</td></tr>`}</tbody>
            </table>
          </div>
        </div>
      </div>`;
    // KPI monthly chart
    if(CHARTS.kpiM) CHARTS.kpiM.destroy();
    CHARTS.kpiM=new Chart(document.getElementById("kpi-monthly"),{type:"bar",data:{labels:kpi.monthly.map(m=>m.m),datasets:[{label:"รับงาน",data:kpi.monthly.map(m=>m.total),backgroundColor:"rgba(0,200,255,.25)",borderColor:"rgba(0,200,255,.7)",borderWidth:1.5,borderRadius:3},{label:"เสร็จ",data:kpi.monthly.map(m=>m.done),backgroundColor:"rgba(0,230,118,.25)",borderColor:"rgba(0,230,118,.7)",borderWidth:1.5,borderRadius:3}]},options:{responsive:true,plugins:{legend:{labels:{font:{size:10}}}},scales:{x:{grid:{color:"rgba(37,43,58,.4)"}},y:{grid:{color:"rgba(37,43,58,.4)"},ticks:{stepSize:1}}}}});
  }catch(e){toast(e.message,"err");}
}

/* ══ SETTINGS ════════════════════════════════════════════ */
async function loadSettings(){
  const[settings,techs]=await Promise.all([api("GET","/api/settings"),api("GET","/api/technicians")]);
  TECHS=techs||[];
  const s=settings||{};
  document.getElementById("view-settings").innerHTML=`
    <div class="fc" style="max-width:620px;">
      <div class="fc-t">⚙️ ตั้งค่าระบบ</div>
      <div class="fc-s">จัดการบริษัท, ช่าง, PIN, KPI และ Notification</div>

      <div class="sec-c">
        <div class="sec-h"><h3>🏢 ข้อมูลบริษัท</h3></div>
        <div class="sec-b">
          <div class="fg2">
            <div class="fgg full"><label class="lbl">ชื่อบริษัท</label><input class="fi" id="set-company" value="${s.company_name||""}"/></div>
          </div>
          <button class="btn bp" onclick="saveSettings(['company_name'])" style="font-size:12px;margin-top:10px;">💾 บันทึก</button>
        </div>
      </div>

      <div class="sec-c">
        <div class="sec-h"><h3>👷 ทีมช่าง (${TECHS.length} คน)</h3><button class="btn bp" onclick="openTechModal(null)" style="font-size:12px;">+ เพิ่มช่าง</button></div>
        <div class="sec-b">
          <div style="flex-wrap:wrap;display:flex;margin-bottom:12px;">${TECHS.map(t=>`<span class="tag">${t.name}${t.phone?` · ${t.phone}`:""}<span class="x" onclick="if(!confirm('ลบ ${t.name}?'))return;api('DELETE','/api/technicians/${t.id}').then(()=>{toast('🗑 ลบแล้ว','warn');loadSettings();})">×</span></span>`).join("")||`<span style="font-size:12px;color:var(--t3)">ยังไม่มีช่าง</span>`}</div>
        </div>
      </div>

      <div class="sec-c">
        <div class="sec-h"><h3>🔐 เปลี่ยน PIN</h3></div>
        <div class="sec-b">
          <div class="fg2">
            <div class="fgg"><label class="lbl">สำหรับ</label><select class="fi" id="pin-role"><option value="admin">🛠 Admin</option><option value="tech">👷 Technician Team</option></select></div>
            <div class="fgg"><label class="lbl">PIN ใหม่ (4-8 หลัก)</label><input class="fi" id="new-pin" type="password" inputmode="numeric" maxlength="8" placeholder="••••" style="font-family:var(--fm);font-size:18px;letter-spacing:.1em"/></div>
          </div>
          <button class="btn bp" onclick="changePin()" style="font-size:12px;margin-top:10px;">🔐 บันทึก PIN ใหม่</button>
        </div>
      </div>

      <div class="sec-c">
        <div class="sec-h"><h3>📈 เป้าหมาย KPI</h3></div>
        <div class="sec-b">
          <div class="fg2">
            <div class="fgg"><label class="lbl">MTTR เป้าหมาย (ชม.)</label><input class="fi" id="set-mttr" type="number" min="1" value="${s.kpi_mttr_target||4}"/></div>
            <div class="fgg"><label class="lbl">อัตราเสร็จงานเป้าหมาย (%)</label><input class="fi" id="set-comp" type="number" min="1" max="100" value="${s.kpi_completion||90}"/></div>
          </div>
          <button class="btn bp" onclick="saveSettings(['kpi_mttr_target','kpi_completion'])" style="font-size:12px;margin-top:10px;">💾 บันทึก</button>
        </div>
      </div>

      <div class="sec-c">
        <div class="sec-h"><h3>🔔 การแจ้งเตือน</h3></div>
        <div class="sec-b">
          <div class="fg2">
            <div class="fgg"><label class="lbl">LINE Notify Token</label><input class="fi" id="set-line" value="${s.line_token||""}" type="password" placeholder="Token จาก notify-bot.line.me"/></div>
            <div class="fgg"><label class="lbl">Email แจ้งเตือน</label><input class="fi" id="set-email" type="email" value="${s.email_to||""}" placeholder="admin@company.com"/></div>
          </div>
          <button class="btn bp" onclick="saveSettings(['line_token','email_to'])" style="font-size:12px;margin-top:10px;">💾 บันทึก</button>
        </div>
      </div>

      <div class="sec-c">
        <div class="sec-h"><h3>💾 ข้อมูลระบบ</h3></div>
        <div class="sec-b">
          <div style="font-size:13px;color:var(--t2);line-height:2;margin-bottom:12px;">
            ใบแจ้งซ่อม <b style="color:var(--tx)">${ALL_TICKETS.length}</b> รายการ · ช่าง <b style="color:var(--tx)">${TECHS.length}</b> คน · อะไหล่ <b style="color:var(--tx)">${ALL_SPARE.length}</b> รายการ
          </div>
          <div style="display:flex;gap:9px;flex-wrap:wrap;">
            <button class="btn bg" onclick="exportCSV()" style="font-size:12px;">⬇ Export CSV</button>
            <button class="btn bg" onclick="exportAll()" style="font-size:12px;">💾 Export JSON</button>
          </div>
        </div>
      </div>
    </div>`;
}

const SET_MAP={company_name:"set-company",kpi_mttr_target:"set-mttr",kpi_completion:"set-comp",line_token:"set-line",email_to:"set-email"};
async function saveSettings(keys){
  const d={};
  for(const k of keys){const el=document.getElementById(SET_MAP[k]);if(el)d[k]=el.value;}
  try{await api("PUT","/api/settings",d);toast("✅ บันทึกแล้ว");}catch(e){toast(e.message,"err");}
}

async function changePin(){
  const role=document.getElementById("pin-role").value;
  const pin=document.getElementById("new-pin").value;
  if(!pin||pin.length<4){toast("PIN ต้องมีอย่างน้อย 4 หลัก","err");return;}
  try{await api("POST","/api/auth/change-pin",{role,new_pin:pin});document.getElementById("new-pin").value="";toast("✅ เปลี่ยน PIN แล้ว");}catch(e){toast(e.message,"err");}
}

function openTechModal(){
  openModal("เพิ่มช่างใหม่","",`
    <div class="fg2">
      <div class="fgg full"><label class="lbl">ชื่อช่าง *</label><input class="fi" id="tech-name" placeholder="ชื่อ-นามสกุล"/></div>
      <div class="fgg"><label class="lbl">เบอร์โทร</label><input class="fi" id="tech-phone"/></div>
      <div class="fgg"><label class="lbl">แผนก</label><input class="fi" id="tech-dept" placeholder="เช่น ฝ่ายซ่อมบำรุง"/></div>
    </div>`,
    `<button class="btn bg" onclick="closeModal()">ยกเลิก</button><button class="btn bp" onclick="saveTech()">บันทึก</button>`
  );
}
async function saveTech(){
  const d={name:document.getElementById("tech-name").value.trim(),phone:document.getElementById("tech-phone").value,dept:document.getElementById("tech-dept").value};
  if(!d.name){toast("กรุณาระบุชื่อ","err");return;}
  try{await api("POST","/api/technicians",d);toast("✅ เพิ่มช่างแล้ว");closeModal();loadSettings();loadTechs();}catch(e){toast(e.message,"err");}
}

/* ══ TECH DASHBOARD ═══════════════════════════════════════ */
async function loadTechDash(){
  try{
    const[tickets,spare]=await Promise.all([api("GET","/api/tickets?status=open")||[],api("GET","/api/spare?low=1")||[]]);
    const myTickets=(tickets||[]).filter(t=>t.assigned_to===USER||t.assigned_to.includes(USER));
    const inProgress=(tickets||[]).filter(t=>t.status==="in-progress");
    document.getElementById("view-tech-dash").innerHTML=`
      <div class="sg" style="grid-template-columns:repeat(3,1fr);">
        <div class="sc c2"><div class="sc-l">งานที่ได้รับมอบหมาย</div><div class="sc-v">${myTickets.length}</div><div class="sc-s">ของฉัน</div></div>
        <div class="sc c1"><div class="sc-l">งานรอดำเนินการ</div><div class="sc-v">${(tickets||[]).length}</div><div class="sc-s">ทั้งทีม</div></div>
        <div class="sc c3"><div class="sc-l">อะไหล่ใกล้หมด</div><div class="sc-v">${(spare||[]).length}</div><div class="sc-s">ต้องสั่งเพิ่ม</div></div>
      </div>
      <div class="tech-dash-grid">
        <div class="tdc">
          <h3>📋 งานของฉัน (${myTickets.length})</h3>
          ${myTickets.length?myTickets.map(t=>`<div class="my-ticket" onclick="filterStatus('all');showView('tickets');openDetail('${t.id}')">
            <div style="flex:1;min-width:0">
              <div style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${t.title}</div>
              <div style="font-size:11px;color:var(--t2);margin-top:2px">${t.location} · ${fmtD(t.created_at)}</div>
            </div>
            <div>${pbadge(t.priority)}</div>
          </div>`).join(""):
          `<div style="text-align:center;padding:24px;color:var(--t3)"><div style="font-size:28px;margin-bottom:8px">✅</div><p>ไม่มีงานค้างอยู่</p></div>`}
        </div>
        <div class="tdc">
          <h3>⚠️ อะไหล่ใกล้หมด/หมด</h3>
          ${(spare||[]).length?(spare||[]).map(p=>`<div class="my-ticket" onclick="loadSpare();showView('spare');setTimeout(()=>openSpareDetail('${p.id}'),300)">
            <div style="flex:1;min-width:0">
              <div style="font-size:13px;font-weight:600">${p.name}</div>
              <div style="font-size:11px;color:var(--t2);margin-top:2px">${p.category} · ${p.location||"—"}</div>
            </div>
            <div style="text-align:right">
              <div style="font-family:var(--fm);font-size:15px;font-weight:700;color:${p.qty===0?"var(--rd)":"var(--wn)"}">${p.qty}</div>
              <div style="font-size:10px;color:var(--t3)">${p.unit}</div>
            </div>
          </div>`).join(""):
          `<div style="text-align:center;padding:24px;color:var(--t3)"><div style="font-size:28px;margin-bottom:8px">🗃️</div><p>สต็อกปกติทั้งหมด</p></div>`}
        </div>
      </div>
      <div class="tbar"><div class="tbar-t">งานทั้งหมดที่รอดำเนินการ</div></div>
      <div class="tw">${buildTable(tickets||[],true)}</div>`;
    applyRole();
  }catch(e){toast(e.message,"err");}
}

/* ══ TECHNICIANS ═════════════════════════════════════════ */
async function loadTechs(){
  TECHS=await api("GET","/api/technicians")||[];
}

/* ══ USER PORTAL ═════════════════════════════════════════ */
function uTab(t,el){
  document.querySelectorAll(".u-tab").forEach(x=>x.classList.remove("on"));
  if(el) el.classList.add("on");
  document.getElementById("uv-form").style.display=t==="form"?"block":"none";
  document.getElementById("uv-track").style.display=t==="track"?"block":"none";
}
function resetUForm(){
  ["uf-name","uf-dept","uf-phone","uf-loc","uf-title","uf-desc"].forEach(id=>document.getElementById(id).value="");
  ["uf-type","uf-pri"].forEach(id=>document.getElementById(id).value="");
  document.getElementById("uf-err").style.display="none";
}
async function submitUForm(){
  const f={reporter:document.getElementById("uf-name").value.trim(),dept:document.getElementById("uf-dept").value,phone:document.getElementById("uf-phone").value.trim(),location:document.getElementById("uf-loc").value.trim(),title:document.getElementById("uf-title").value.trim(),type:document.getElementById("uf-type").value,priority:document.getElementById("uf-pri").value,description:document.getElementById("uf-desc").value.trim()};
  const errEl=document.getElementById("uf-err");
  const miss=["reporter","phone","location","title","type","priority","description"].filter(k=>!f[k]);
  if(miss.length){errEl.textContent="⚠️ กรุณากรอกข้อมูลให้ครบ";errEl.style.display="block";return;}
  errEl.style.display="none";
  const btn=document.getElementById("uf-btn");btn.disabled=true;btn.textContent="กำลังส่ง...";
  try{
    const t=await api("POST","/api/tickets",f);if(!t)return;
    LAST_WO=t.id;document.getElementById("suc-id").textContent=t.id;
    document.getElementById("u-form-area").style.display="none";
    document.getElementById("u-suc").style.display="block";
    toast("✅ ส่งแล้ว "+t.id);
  }catch(e){errEl.textContent="❌ "+e.message;errEl.style.display="block";}
  finally{btn.disabled=false;btn.textContent="📨 ส่งใบแจ้งซ่อม";}
}
function copyId(){navigator.clipboard?.writeText(LAST_WO).then(()=>toast("📋 คัดลอก "+LAST_WO+" แล้ว")).catch(()=>{});}
async function doTrack(){
  const id=document.getElementById("tr-inp").value.trim().toUpperCase();
  const area=document.getElementById("tr-result");
  if(!id) return;
  try{
    const t=await api("GET","/api/track/"+id);
    if(!t){area.innerHTML=`<div class="emp"><div style="font-size:26px;margin-bottom:8px">🔍</div><p>ไม่พบ <b style="color:var(--ac);font-family:var(--fm)">${id}</b></p></div>`;return;}
    const SO={open:0,"in-progress":1,done:2};
    const STEPS=[["📋","รับเรื่อง"],["🔧","กำลังซ่อม"],["✅","เสร็จสิ้น"]];
    const cur=SO[t.status]??0;
    area.innerHTML=`<div style="background:var(--su);border:1px solid var(--bd);border-radius:10px;overflow:hidden;animation:mup .2s ease">
      <div style="padding:13px 16px;border-bottom:1px solid var(--bd);display:flex;align-items:flex-start;justify-content:space-between;gap:10px;">
        <div><div style="font-family:var(--fm);font-size:11px;color:var(--ac);margin-bottom:3px">${t.id}</div><div style="font-size:14px;font-weight:700">${t.title}</div></div>
        ${sbadge(t.status)}
      </div>
      <div style="padding:14px">
        <div style="display:flex;margin-bottom:16px">${STEPS.map(([ic,lb],i)=>{const ds=i<cur,cs=i===cur;return `<div style="flex:1;display:flex;flex-direction:column;align-items:center;position:relative">${i<2?`<div style="position:absolute;top:11px;left:55%;right:-45%;height:2px;background:${ds?"var(--ac)":"var(--bd)"}"></div>`:""}<div style="width:22px;height:22px;border-radius:50%;border:2px solid ${cs?"var(--a2)":ds?"var(--ac)":"var(--bd)"};background:${cs?"rgba(255,96,48,.12)":ds?"rgba(0,200,255,.1)":"var(--bg)"};display:grid;place-items:center;font-size:10px;position:relative;z-index:1;box-shadow:${cs?"0 0 9px rgba(255,96,48,.35)":"none"}">${ic}</div><div style="font-size:10px;color:${cs?"var(--a2)":ds?"var(--ac)":"var(--t3)"};margin-top:4px;text-align:center;font-family:var(--fm)">${lb}</div></div>`;}).join("")}</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:14px;">
          <div style="background:var(--bg);border:1px solid var(--bd);border-radius:6px;padding:8px 11px"><div style="font-size:10px;font-family:var(--fm);color:var(--t3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:2px">สถานที่</div><div style="font-size:12px">📍 ${t.location}</div></div>
          <div style="background:var(--bg);border:1px solid var(--bd);border-radius:6px;padding:8px 11px"><div style="font-size:10px;font-family:var(--fm);color:var(--t3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:2px">ช่าง</div><div style="font-size:12px">${t.assigned_to?`<span style="color:var(--ok)">🔧 ${t.assigned_to}</span>`:`<span class="bdg b-sop">รอมอบหมาย</span>`}</div></div>
          <div style="background:var(--bg);border:1px solid var(--bd);border-radius:6px;padding:8px 11px"><div style="font-size:10px;font-family:var(--fm);color:var(--t3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:2px">วันที่แจ้ง</div><div style="font-size:12px">📅 ${fmtD(t.created_at)}</div></div>
          <div style="background:var(--bg);border:1px solid var(--bd);border-radius:6px;padding:8px 11px"><div style="font-size:10px;font-family:var(--fm);color:var(--t3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:2px">กำหนดเสร็จ</div><div style="font-size:12px">${t.due_date||"—"}</div></div>
        </div>
        <div style="font-size:10px;font-family:var(--fm);color:var(--t3);letter-spacing:.08em;text-transform:uppercase;margin-bottom:9px">ประวัติความคืบหน้า</div>
        ${buildTL(t.timeline||[])}
      </div>
    </div>`;
  }catch(e){area.innerHTML=`<div class="emp"><div style="font-size:26px;margin-bottom:8px">🔍</div><p>ไม่พบ <b style="color:var(--ac);font-family:var(--fm)">${id}</b></p></div>`;}
}

/* ══ EXPORT ══════════════════════════════════════════════ */
function exportCSV(){
  if(!ALL_TICKETS.length){toast("ไม่มีข้อมูล","warn");return;}
  const h="เลขที่,หัวข้อ,สถานที่,ประเภท,ระดับ,สถานะ,ผู้แจ้ง,เบอร์,ช่าง,วันที่แจ้ง,กำหนดเสร็จ\n";
  const r=ALL_TICKETS.map(t=>[t.id,`"${t.title}"`,t.location,t.type,t.priority,t.status,t.reporter,t.phone||"",t.assigned_to||"",fmtD(t.created_at),t.due_date||""].join(","));
  const b=new Blob(["\uFEFF"+h+r.join("\n")],{type:"text/csv;charset=utf-8"});
  const a=document.createElement("a");a.href=URL.createObjectURL(b);a.download=`cmms_${new Date().toISOString().split("T")[0]}.csv`;a.click();
  toast("⬇️ Export "+ALL_TICKETS.length+" รายการแล้ว");
}
async function exportAll(){
  try{
    const[tks,pms,spare]=await Promise.all([api("GET","/api/tickets"),api("GET","/api/pm"),api("GET","/api/spare")]);
    const b=new Blob([JSON.stringify({exported:new Date().toISOString(),tickets:tks,pm:pms,spare},null,2)],{type:"application/json"});
    const a=document.createElement("a");a.href=URL.createObjectURL(b);a.download=`cmms_backup_${new Date().toISOString().split("T")[0]}.json`;a.click();
    toast("💾 Export JSON แล้ว");
  }catch(e){toast(e.message,"err");}
}

/* ══ MODAL ═══════════════════════════════════════════════ */
function openModal(title,sub,body,foot){
  document.getElementById("modal-title").textContent=title;
  document.getElementById("modal-sub").textContent=sub;
  document.getElementById("modal-body").innerHTML=body;
  document.getElementById("modal-foot").innerHTML=foot;
  document.getElementById("modal-bg").style.display="flex";
}
function closeModal(){document.getElementById("modal-bg").style.display="none";}

/* ══ INIT ═════════════════════════════════════════════════ */
window.addEventListener("keydown",e=>{ if(e.key==="Escape"){closeDetail();closeModal();document.getElementById("spare-detail-modal").style.display="none";} });
if(TOKEN&&ROLE){
  ["scr-login","scr-user"].forEach(s=>{const el=document.getElementById(s);if(el)el.style.display="none";});
  document.getElementById("scr-admin").style.display="block";
  applyRole(); loadDashboard(); loadTechs();
}else{
  document.getElementById("scr-login").style.display="flex";
  ["scr-user","scr-admin"].forEach(s=>{const el=document.getElementById(s);if(el)el.style.display="none";});
}
</script>
</body>
</html>
