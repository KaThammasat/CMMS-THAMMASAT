# CMMS PRO — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# JWT Secret (change this to a random string in production!)
JWT_SECRET=cmms-pro-secret-change-me-in-production-2024

# Database path (Railway uses /app/cmms.db)
DB_PATH=./cmms.db

# LINE Notify Token (optional — get from notify.line.me)
LINE_TOKEN=

# Timezone
TZ=Asia/Bangkok
