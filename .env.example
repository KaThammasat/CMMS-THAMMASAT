# ============================================================
# CMMS THAMMASAT INDUSTRIAL - Environment Configuration
# Copy to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cmms_thammasat
DB_USER=cmms_user
DB_PASSWORD=cmms_secure_password_change_me
DB_POOL_MAX=20
DB_SSL=false

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=cmms_redis_password_change_me

# ─── JWT ─────────────────────────────────────────────────────
# MUST be at least 32 characters in production
JWT_SECRET=cmms_jwt_secret_change_in_production_must_be_at_least_32_chars
JWT_EXPIRES=8h
JWT_REFRESH_EXPIRES=7d

# ─── Frontend (React) ────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000/api/v1
REACT_APP_SOCKET_URL=http://localhost:5000

# ─── Docker / Production ─────────────────────────────────────
GRAFANA_PASSWORD=cmms_grafana_admin_password
DEPLOY_HOST=your-server-ip
DEPLOY_USER=ubuntu
